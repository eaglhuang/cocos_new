  "elevation": {
    "shadowColor":  "#000000",
    "shadowNone":   { "offsetY": 0,  "blur": 0,  "opacity": 0   },
    "shadowSm":     { "offsetY": 2,  "blur": 4,  "opacity": 0.2 },
    "shadowMd":     { "offsetY": 4,  "blur": 12, "opacity": 0.3 },
    "shadowDefault": { "offsetY": 4, "blur": 12, "opacity": 0.24 },
    "shadowLg":     { "offsetY": 12, "blur": 24, "opacity": 0.4 },
    "glowGold":     [
      { "offsetY": 0, "blur": 30, "opacity": 0.75, "color": "#FFC107" },
      { "offsetY": 0, "blur": 60, "opacity": 0.4, "color": "#FFC107" }
    ],
    "glowRainbow":  [
      { "offsetY": 0, "blur": 40, "opacity": 0.9, "color": "#00FBFF" },
      { "offsetY": 0, "blur": 80, "opacity": 0.5, "color": "#00FBFF" }
    ],
    "glowJade":     [
      { "offsetY": 0, "blur": 25, "opacity": 0.7, "color": "#8CCFC4" },
      { "offsetY": 0, "blur": 50, "opacity": 0.35, "color": "#8CCFC4" }
    ]
  },

  "animation": {
    "durationFast":   0.15,
    "durationNormal": 0.25,
    "durationSlow":   0.4,
    "easingDefault":  "cubicBezier(0.4, 0, 0.2, 1)",
    "easingEnter":    "cubicBezier(0, 0, 0.2, 1)",
    "easingExit":     "cubicBezier(0.4, 0, 1, 1)"
