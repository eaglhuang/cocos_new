  "spacing": {
    "xs":      4,
    "sm":      8,
    "md":      12,
    "lg":      16,
    "xl":      24,
    "xxl":     32,
    "section": 48
  },

  "shape": {
    "radiusNone":      0,
    "radiusSm":        4,
    "radiusMd":        8,
    "radiusLg":        16,
    "radiusXl":        24,
    "radiusFull":      9999,
    "preferredCorner": "radiusMd"
  },

  "opacity": {
    "overlay":       0.75,
    "disabled":      0.38,
    "hover":         0.08,
    "pressed":       0.12,
    "glassmorphism": 0.75
