{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "param-tune-manifest.schema.json",
  "title": "UIFactoryParamTuneManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "screenId",
    "sourceFamilyMap",
    "generatedAt",
    "taskCount",
    "tasks",
    "warnings"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "../../schemas/param-tune-manifest.schema.json" },
    "screenId": { "type": "string", "minLength": 1 },
    "sourceFamilyMap": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "taskCount": { "type": "integer", "minimum": 0 },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId",
          "screenId",
          "zone",
          "taskType",
          "label",
          "family",
          "recipe",
          "reason",
          "adjustTargets",
          "suggestedOps",
          "widgetRefs",
          "templateRefs"
        ],
        "properties": {
          "taskId": { "type": "string", "minLength": 1 },
          "screenId": { "type": "string", "minLength": 1 },
          "zone": { "type": "string", "minLength": 1 },
          "taskType": { "type": "string", "const": "param-tune" },
          "label": { "type": "string", "minLength": 1 },
          "family": { "type": "string", "minLength": 1 },
          "recipe": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "adjustTargets": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "suggestedOps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "widgetRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "templateRefs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}