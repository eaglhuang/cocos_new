{
  "recipeType": "screen-recipe",
  "recipeVersion": 1,
  "screenId": "shop-main-screen",
  "uiId": "ShopMain",
  "familyId": "rail-list",
  "variantId": "shop-main-v1",
  "bundle": "lobby_ui",
  "layer": "Game",
  "controllerKind": "composite-panel",
  "controllerClass": "ShopMainComposite",
  "layoutId": "shop-main-main",
  "skinId": "shop-main-default",
  "contentSchemaId": "shop-main-content",
  "mapperClass": "ShopMainMapper",
  "bindPolicyClass": "ShopMainBindPathPolicy",
  "dataSources": [
    {
      "sourceId": "title",
      "kind": "entity",
      "required": true,
      "bindPath": "ui.title",
      "owner": "ShopMain",
      "description": "商城"
    },
    {
      "sourceId": "selectedCategory",
      "kind": "ui-state",
      "required": true,
      "bindPath": "shop.selectedCategory",
      "owner": "ShopMain",
      "description": "當前分類（武器/裝備/消耗品）"
    },
    {
      "sourceId": "items",
      "kind": "collection",
      "required": true,
      "bindPath": "shop.items[]",
      "owner": "ShopMain",
      "description": "商品清單"
    },
    {
      "sourceId": "selectedItem",
      "kind": "entity",
      "required": false,
      "bindPath": "shop.selectedItem.description",
      "owner": "ShopMain",
      "description": "選中商品"
    },
    {
      "sourceId": "gold",
      "kind": "summary",
      "required": true,
      "bindPath": "player.gold",
      "owner": "ShopMain",
      "description": "金錢餘額"
    },
    {
      "sourceId": "gems",
      "kind": "summary",
      "required": false,
      "bindPath": "player.gems",
      "owner": "ShopMain",
      "description": "元寶餘額"
    },
    {
      "sourceId": "canBuySelected",
      "kind": "ui-state",
      "required": false,
      "bindPath": "shop.canBuySelected",
      "owner": "ShopMain",
      "description": "可購買旗標"
    }
  ],
  "slots": [
    {
      "slotId": "Header",
      "zoneId": "rail-list.header",
      "mode": "toolbar-host"
    },
    {
      "slotId": "TabBar",
      "zoneId": "rail-list.tab-bar",
      "mode": "tab-routed",
      "dataSource": "selectedCategory",
      "routeKeys": [
        "武器",
        "裝備",
        "消耗品分頁切換"
      ],
      "childPanelClass": "ShopMainTabBarChild"
    },
    {
      "slotId": "ItemGrid",
      "zoneId": "rail-list.item-grid",
      "mode": "list-host",
      "dataSource": "items",
      "childPanelClass": "ShopMainItemGridChild"
    },
    {
      "slotId": "CurrencyBar",
      "zoneId": "rail-list.currency-bar",
      "mode": "toolbar-host",
      "dataSource": "gold"
    },
    {
      "slotId": "PurchasePanel",
      "zoneId": "rail-list.purchase-panel",
      "mode": "preview-host",
      "dataSource": "selectedItem",
      "childPanelClass": "ShopMainPurchasePanelChild"
    }
  ],
  "chromeFlags": {
    "hasPortrait": false,
    "hasTopMeta": true,
    "hasBottomSummary": false,
    "hasTabRail": true,
    "hasFooterActions": true,
    "hasOverviewSpecialSlot": false,
    "hasSearchBar": false,
    "hasSortHeader": false,
    "hasLeftRail": false,
    "hasRightPreview": true
  },
  "visualTheme": {
    "skinFamily": "rail-list-default",
    "frameRecipe": "rail-list-v1",
    "tokenTheme": "lobby-ink-gold",
    "ornamentPolicy": "reuse-only"
  },
  "generationPolicy": "reuse-only",
  "validationProfile": "rail-list-game-standard",
  "smokeRoute": "LobbyScene -> open ShopMain"
}
