{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/session-start.js",
        "windows": "node .github/hooks/scripts/session-start.js",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/pre-tool-guard.js",
        "windows": "node .github/hooks/scripts/pre-tool-guard.js",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/post-encode-check.js",
        "windows": "node .github/hooks/scripts/post-encode-check.js",
        "timeout": 20
      }
    ]
  }
}
