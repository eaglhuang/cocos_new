// heroine-toon.effect ???????????????PBR-Toon ?????
// ???????????????????????????????????????????????????????????????????????????????????????????????????????????
//  ?閰????蛔??????Unity URP / ShaderGraph ?????
//  1. Outline-free PBR-Toon Hybrid  ?????????踐????螞謍?
//  2. High-Diffusion Ramp Toon Shadows ??smoothstep ????????
//  3. Fake SSS via Blush Mask        ??????剜???澗走??????
//  4. Material-ID Layering (Metal Mask) ????急? / ????????
//  5. Ethereal Rim Light              ???皝???荔??????????
// ???????????????????????????????????????????????????????????????????????????????????????????????????????????

CCEffect %{
  name: heroine-toon
  techniques:
  - name: opaque
    passes:
    - vert: heroine-toon-vs:vert
      frag: heroine-toon-fs:frag
      properties: &props
        mainTexture:         { value: white }
        controlMap:          { value: black }
        matcapTex:           { value: white }
        u_shadowColor:       { value: [0.65, 0.55, 0.62, 1.0], linear: true, editor: { type: color } }
        u_sssColor:          { value: [1.0, 0.42, 0.38, 1.0],  linear: true, editor: { type: color } }
        u_metalTint:         { value: [0.72, 0.78, 0.88, 1.0], linear: true, editor: { type: color } }
        u_rimColor:          { value: [1.0, 0.88, 0.6, 1.0],   linear: true, editor: { type: color } }
        u_rampSmooth:        { value: 0.25 }
        u_rampOffset:        { value: 0.0 }
        u_sssIntensity:      { value: 0.55 }
        u_metalSpecPower:    { value: 32.0 }
        u_metalSpecStrength: { value: 0.6 }
        u_matcapStrength:    { value: 0.35 }
        u_rimPower:          { value: 2.8 }
        u_rimStrength:       { value: 0.45 }
        u_rimSpread:         { value: 0.3 }
        u_qualityLevel:      { value: 1.0 }

  - name: transparent
    passes:
    - vert: heroine-toon-vs:vert
      frag: heroine-toon-fs:frag
      blendState:
        targets:
        - blend: true
          blendSrc: src_alpha
          blendDst: one_minus_src_alpha
          blendSrcAlpha: src_alpha
          blendDstAlpha: one_minus_src_alpha
      depthStencilState:
        depthWrite: false
      properties: *props
}%


// ???????????????????????????????????????????????????????????????????????????????????????????????????????????
//  Vertex Shader
//  Unity ???勗?謇pdata ??v2f??nityObjectToClipPos / WorldSpaceViewDir
// ???????????????????????????????????????????????????????????????????????????????????????????????????????????
CCProgram heroine-toon-vs %{
  precision highp float;

  #include <builtin/uniforms/cc-global>
  #include <builtin/uniforms/cc-local>

  in vec3 a_position;
  in vec3 a_normal;
  in vec2 a_texCoord;

  out vec2 v_uv;
  out vec3 v_worldNormal;
  out vec3 v_worldPos;
  out vec2 v_matcapUV;
  out float v_rimBasic;

  vec4 vert() {
    vec4 worldPos4   = cc_matWorld * vec4(a_position, 1.0);
    v_worldPos       = worldPos4.xyz;
    v_worldNormal    = normalize((cc_matWorldIT * vec4(a_normal, 0.0)).xyz);
    v_uv             = a_texCoord;

    // MatCap UV嚗? View Space Normal 撠???[0,1] 鞎澆?摨扳?
    // Unity 撠嚗ul(UNITY_MATRIX_V, float4(worldNormal, 0)).xy * 0.5 + 0.5
    vec3 worldN      = v_worldNormal;
    vec3 viewNormal  = normalize((cc_matView * vec4(worldN, 0.0)).xyz);
    v_matcapUV       = viewNormal.xy * 0.5 + 0.5;

    // Rim Fresnel ?蹇??契??殷??
    vec3 viewDir     = normalize(cc_cameraPos.xyz - worldPos4.xyz);
    float NdotV      = max(dot(v_worldNormal, viewDir), 0.0);
    v_rimBasic       = 1.0 - NdotV;

    return cc_matProj * cc_matView * worldPos4;
  }
}%


// ???????????????????????????????????????????????????????????????????????????????????????????????????????????
//  Fragment Shader
// ???????????????????????????????????????????????????????????????????????????????????????????????????????????
CCProgram heroine-toon-fs %{
  precision highp float;

  #include <output>

  in vec2 v_uv;
  in vec3 v_worldNormal;
  in vec3 v_worldPos;
  in vec2 v_matcapUV;
  in float v_rimBasic;

  uniform sampler2D mainTexture;
  uniform sampler2D controlMap;
  uniform sampler2D matcapTex;

    // UBO rule: 4x vec4 (colors) + 10x float (scalars), vec4 first
  // no target: -- direct property name mapping
  uniform HeroineToon {
    vec4  u_shadowColor;
    vec4  u_sssColor;
    vec4  u_metalTint;
    vec4  u_rimColor;
    float u_rampSmooth;
    float u_rampOffset;
    float u_sssIntensity;
    float u_metalSpecPower;
    float u_metalSpecStrength;
    float u_matcapStrength;
    float u_rimPower;
    float u_rimStrength;
    float u_rimSpread;
    float u_qualityLevel;
  };

  vec4 frag() {
    // 1. 霈?蝷鞎澆?
    vec4 baseColor = texture(mainTexture, v_uv);

    // 2. ??對??謖?R=Ramp??喳?  G=BlushMask  B=MetalMask
    vec3  ctrl      = texture(controlMap, v_uv).rgb;
    float rampBias  = ctrl.r;
    float blushMask = ctrl.g;
    float metalMask = ctrl.b;

    // 3. Half-Lambert ?????伐
    // Unity ???勗?謕蜿otL * 0.5 + 0.5??alf Lambert trick??
    vec3  N         = normalize(v_worldNormal);
    vec3  L         = normalize(-cc_mainLitDir.xyz);
    float NdotL     = dot(N, L);
    float halfLambert = clamp(NdotL * 0.5 + 0.5 + (rampBias - 0.5) * 0.4 + u_rampOffset, 0.0, 1.0);

    // 4. smoothstep Ramp ??螞謍減???
    float rampEdge  = 0.45;
    float half_s    = u_rampSmooth * 0.5;
    float toonRamp  = smoothstep(rampEdge - half_s, rampEdge + half_s, halfLambert);

    // ?????剁?垮??嚗豢紗??u_shadowColor
    vec3 shadedColor = mix(baseColor.rgb * u_shadowColor.rgb, baseColor.rgb, toonRamp);

    // 5. Fake SSS ??????剜????
    // sssBand?城謓?Ramp ????????????edge0 < edge1 ?????????
    float sssBand  = smoothstep(0.1, 0.4, toonRamp) * (1.0 - smoothstep(0.4, 0.7, toonRamp));
    float sssAmt   = sssBand * blushMask * u_sssIntensity * u_qualityLevel;
    shadedColor    = mix(shadedColor, shadedColor + u_sssColor.rgb * 0.5, clamp(sssAmt, 0.0, 1.0));

    // 6. ?惇?釭瘛瑕?嚗atCap ?啣??? + Blinn-Phong 擃?
    vec3 matcapColor = texture(matcapTex, v_matcapUV).rgb;

    vec3  V         = normalize(cc_cameraPos.xyz - v_worldPos);
    vec3  H         = normalize(L + V);
    float NdotH     = max(dot(N, H), 0.0);
    float spec      = pow(NdotH, u_metalSpecPower) * u_metalSpecStrength;

    vec3 metalColor = shadedColor * u_metalTint.rgb
                    + matcapColor * u_matcapStrength
                    + vec3(spec);

    vec3 finalColor = mix(shadedColor, metalColor, metalMask);

    // 7. ?皝?????????thereal Rim Light??
    float rimFresnel = pow(v_rimBasic, u_rimPower);
    float rimWide    = pow(v_rimBasic, max(u_rimPower * 0.4, 0.1)) * u_rimSpread;
    float rimLitBias = smoothstep(0.0, 0.6, halfLambert);
    float rimTotal   = clamp(rimFresnel + rimWide, 0.0, 1.0)
                     * u_rimStrength * u_qualityLevel
                     * mix(0.3, 1.0, rimLitBias);
    finalColor      += u_rimColor.rgb * rimTotal;

    // 8. ?蝯撓?綽?靽??? Alpha嚗
    return CCFragOutput(vec4(finalColor, baseColor.a));
  }
}%

