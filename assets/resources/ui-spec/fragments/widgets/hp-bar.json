{
  "id": "hp-bar",
  "description": "血量條（填充 + 文字 + 陣營色）",
  "category": "display",
  "params": {
    "faction": { "type": "enum", "variants": ["player", "enemy"], "default": "player" },
    "showLabel": { "type": "boolean", "default": true }
  },
  "layout": {
    "type": "container",
    "name": "HpBar",
    "id": "hpBar",
    "width": "100%",
    "height": 24,
    "children": [
      {
        "type": "panel",
        "name": "HpBarTrack",
        "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
        "skinSlot": "widget.hpbar.track"
      },
      {
        "type": "panel",
        "name": "HpBarFill",
        "id": "hpBarFill",
        "widget": { "top": 2, "bottom": 2, "left": 2 },
        "width": "100%",
        "height": 20,
        "skinSlot": "widget.hpbar.fill.${faction}"
      },
      {
        "type": "label",
        "name": "HpBarLabel",
        "id": "hpBarLabel",
        "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
        "styleSlot": "widget.hpbar.label",
        "text": ""
      }
    ]
  },
  "defaultSkinSlots": {
    "widget.hpbar.track": {
      "kind": "color-rect",
      "color": "surfaceGray"
    },
    "widget.hpbar.fill.player": {
      "kind": "color-rect",
      "color": "hpBarAlly"
    },
    "widget.hpbar.fill.enemy": {
      "kind": "color-rect",
      "color": "hpBarEnemy"
    },
    "widget.hpbar.label": {
      "kind": "label-style",
      "fontSize": 16,
      "color": "colorWhite",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true
    }
  }
}
