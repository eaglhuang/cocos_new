{
  "id": "battle-log-main",
  "version": 3,
  "canvas": { "fitWidth": true, "fitHeight": true, "safeArea": true, "designWidth": 1920, "designHeight": 1080 },
  "root": {
    "type": "container",
    "name": "SidePanelRoot",
    "width": "10%",
    "widget": { "right": 0, "top": 88 },
    "layout": { "type": "vertical", "spacing": 0 },
    "children": [
      {
        "type": "panel",
        "name": "ControlBar",
        "width": "100%",
        "height": 40,
        "skinSlot": "log.header.bg",
        "layout": { "type": "horizontal", "spacing": 8, "paddingLeft": 12, "paddingRight": 12 },
        "children": [
          { "type": "button", "name": "BtnAuto",    "id": "btnAuto",    "width": 32, "height": 32, "skinSlot": "log.btn.auto" },
          { "type": "button", "name": "BtnSpeed",   "id": "btnSpeed",   "width": 32, "height": 32, "skinSlot": "log.btn.speed" },
          { "type": "button", "name": "BtnSetting", "id": "btnSetting", "width": 32, "height": 32, "skinSlot": "log.btn.setting" }
        ]
      },
      {
        "type": "panel",
        "name": "BattleLogPanel",
        "id": "battleLogPanel",
        "width": "100%",
        "height": 410,
        "skinSlot": "log.root.bg",
        "children": [
          {
            "type": "panel",
            "name": "Header",
            "width": "100%",
            "height": 34,
            "skinSlot": "log.header.bg",
            "layout": { "type": "horizontal", "spacing": 8, "paddingLeft": 12, "paddingRight": 12 },
            "children": [
              { "type": "label", "name": "Title", "id": "logTitle", "width": 140, "height": 28, "text": "戰鬥日誌", "styleSlot": "log.label.title" }
            ]
          },
          {
            "type": "scroll-view",
            "name": "ScrollView",
            "id": "scrollView",
            "width": "100%",
            "height": 348,
            "children": [
              {
                "type": "container",
                "name": "ContentNode",
                "id": "contentNode",
                "width": "100%",
                "height": 340,
                "children": [
                  { "type": "label", "name": "LogLabel", "id": "logLabel", "width": "100%", "height": 340, "styleSlot": "log.label.content" }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "button",
        "name": "BtnCollapse",
        "id": "btnCollapse",
        "width": "100%",
        "height": 28,
        "text": "📋 收合",
        "skinSlot": "log.btn.collapse",
        "styleSlot": "log.label.toggle",
        "_comment": "Toggle: collapse hides BattleLogPanel (h→0), button changes to 32x32 icon; expand restores to ~410px with Tween 0.3s"
      }
    ]
  }
}
