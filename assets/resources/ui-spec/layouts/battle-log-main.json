{
  "id": "battle-log-main",
  "version": 3,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "SidePanelRoot",
    "width": "11%",
    "widget": {
      "right": 16,
      "top": 168
    },
    "layout": {
      "type": "vertical",
      "spacing": 0
    },
    "children": [
      {
        "type": "panel",
        "name": "ControlBar",
        "width": "100%",
        "height": 44,
        "skinSlot": "log.header.bg",
        "layout": {
          "type": "horizontal",
          "spacing": 10,
          "paddingLeft": 10,
          "paddingRight": 10
        },
        "children": [
          {
            "type": "button",
            "name": "BtnAuto",
            "id": "btnAuto",
            "width": 32,
            "height": 32,
            "skinSlot": "log.btn.auto",
            "children": [
              {
                "type": "image",
                "name": "AutoIcon",
                "id": "autoIcon",
                "widget": {
                  "top": 8,
                  "left": 8
                },
                "width": 16,
                "height": 16,
                "skinSlot": "log.icon.auto",
                "_doc": "F8 tactical control overlay glyph"
              }
            ]
          },
          {
            "type": "button",
            "name": "BtnSpeed",
            "id": "btnSpeed",
            "width": 32,
            "height": 32,
            "skinSlot": "log.btn.speed",
            "children": [
              {
                "type": "image",
                "name": "SpeedIcon",
                "id": "speedIcon",
                "widget": {
                  "top": 8,
                  "left": 8
                },
                "width": 16,
                "height": 16,
                "skinSlot": "log.icon.speed",
                "_doc": "F8 tactical control overlay glyph"
              }
            ]
          },
          {
            "type": "button",
            "name": "BtnSetting",
            "id": "btnSetting",
            "width": 32,
            "height": 32,
            "skinSlot": "log.btn.setting",
            "children": [
              {
                "type": "image",
                "name": "SettingIcon",
                "id": "settingIcon",
                "widget": {
                  "top": 8,
                  "left": 8
                },
                "width": 16,
                "height": 16,
                "skinSlot": "log.icon.setting",
                "_doc": "F8 tactical control overlay glyph"
              }
            ]
          }
        ]
      },
      {
        "type": "panel",
        "name": "BattleLogPanel",
        "id": "battleLogPanel",
        "width": "100%",
        "height": 344,
        "skinSlot": "log.root.bg",
        "layout": {
          "type": "vertical",
          "spacing": 0
        },
        "children": [
          {
            "type": "panel",
            "name": "Header",
            "width": "100%",
            "height": 36,
            "skinSlot": "log.header.bg",
            "layout": {
              "type": "horizontal",
              "spacing": 8,
              "paddingLeft": 12,
              "paddingRight": 12
            },
            "children": [
              {
                "type": "label",
                "name": "Title",
                "id": "logTitle",
                "width": 140,
                "height": 28,
                "text": "戰鬥日誌",
                "styleSlot": "log.label.title"
              }
            ]
          },
          {
            "type": "scroll-view",
            "name": "ScrollView",
            "id": "scrollView",
            "width": "100%",
            "height": 308,
            "children": [
              {
                "type": "container",
                "name": "ContentNode",
                "id": "contentNode",
                "width": "100%",
                "height": 340,
                "children": [
                  {
                    "type": "label",
                    "name": "LogLabel",
                    "id": "logLabel",
                    "width": "100%",
                    "height": 340,
                    "styleSlot": "log.label.content",
                    "bind": "battleLog.message"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "button",
        "name": "BtnCollapse",
        "id": "btnCollapse",
        "width": "100%",
        "height": 30,
        "text": "戰報",
        "skinSlot": "log.btn.collapse",
        "styleSlot": "log.label.toggle",
        "children": [
          {
            "type": "image",
            "name": "CollapseIcon",
            "id": "collapseIcon",
            "widget": {
              "right": 10,
              "top": 9
            },
            "width": 12,
            "height": 12,
            "skinSlot": "log.icon.collapse",
            "_doc": "F8 tactical control overlay glyph"
          }
        ],
        "_comment": "Toggle: collapse hides BattleLogPanel (h→0), button changes to 32x32 icon; expand restores to ~410px with Tween 0.3s"
      }
    ]
  }
}
