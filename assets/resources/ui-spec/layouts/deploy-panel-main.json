{
  "id": "deploy-panel-main",
  "version": 1,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "DeployPanelRoot",
    "widget": {
      "bottom": 0,
      "left": 0,
      "right": 0
    },
    "height": 48,
    "children": [
      {
        "type": "panel",
        "name": "InfoRow",
        "active": false,
        "widget": {
          "left": 0,
          "right": 0
        },
        "height": 36,
        "layout": {
          "type": "horizontal",
          "spacing": 12,
          "paddingLeft": 24,
          "paddingRight": 24
        },
        "children": [
          {
            "type": "label",
            "name": "CostLabel",
            "id": "costLabel",
            "width": 180,
            "height": 28,
            "styleSlot": "deploy.label.cost"
          },
          {
            "type": "label",
            "name": "HintLabel",
            "id": "hintLabel",
            "width": 300,
            "height": 28,
            "styleSlot": "deploy.label.hint"
          }
        ]
      },
      {
        "type": "container",
        "name": "Toast",
        "id": "toastContainer",
        "widget": {
          "top": -60,
          "horizontalCenter": 0
        },
        "width": 400,
        "height": 60,
        "active": false
      }
    ]
  },
  "validation": {
    "exceptions": {
      "no-empty-container": "Toast 為執行期動態填充容器，不需預設子節點"
    }
  }
}
