{
  "id": "deploy-panel-main",
  "version": 1,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "DeployPanelRoot",
    "widget": {
      "bottom": 0,
      "left": 0,
      "right": 0
    },
    "height": 160,
    "skinSlot": "deploy.root.bg",
    "children": [
      {
        "type": "panel",
        "name": "SlotRow",
        "id": "slotRow",
        "widget": {
          "left": 0,
          "right": 0
        },
        "height": 120,
        "layout": {
          "type": "horizontal",
          "spacing": 16,
          "paddingLeft": 24,
          "paddingRight": 24
        },
        "children": [
          {
            "type": "button",
            "name": "SlotCavalry",
            "id": "btnCavalry",
            "width": 100,
            "height": 100,
            "skinSlot": "deploy.slot.card",
            "children": [
              {
                "type": "label",
                "name": "Label",
                "width": 100,
                "height": 24,
                "text": "騎兵",
                "styleSlot": "deploy.label.troop"
              }
            ]
          },
          {
            "type": "button",
            "name": "SlotInfantry",
            "id": "btnInfantry",
            "width": 100,
            "height": 100,
            "skinSlot": "deploy.slot.card",
            "children": [
              {
                "type": "label",
                "name": "Label",
                "width": 100,
                "height": 24,
                "text": "步兵",
                "styleSlot": "deploy.label.troop"
              }
            ]
          },
          {
            "type": "button",
            "name": "SlotShield",
            "id": "btnShield",
            "width": 100,
            "height": 100,
            "skinSlot": "deploy.slot.card",
            "children": [
              {
                "type": "label",
                "name": "Label",
                "width": 100,
                "height": 24,
                "text": "盾兵",
                "styleSlot": "deploy.label.troop"
              }
            ]
          },
          {
            "type": "button",
            "name": "SlotArcher",
            "id": "btnArcher",
            "width": 100,
            "height": 100,
            "skinSlot": "deploy.slot.card",
            "children": [
              {
                "type": "label",
                "name": "Label",
                "width": 100,
                "height": 24,
                "text": "弓兵",
                "styleSlot": "deploy.label.troop"
              }
            ]
          },
          {
            "type": "button",
            "name": "SlotPikeman",
            "id": "btnPikeman",
            "width": 100,
            "height": 100,
            "skinSlot": "deploy.slot.card",
            "children": [
              {
                "type": "label",
                "name": "Label",
                "width": 100,
                "height": 24,
                "text": "槍兵",
                "styleSlot": "deploy.label.troop"
              }
            ]
          }
        ]
      },
      {
        "type": "panel",
        "name": "InfoRow",
        "widget": {
          "left": 0,
          "right": 0
        },
        "height": 36,
        "layout": {
          "type": "horizontal",
          "spacing": 12,
          "paddingLeft": 24,
          "paddingRight": 24
        },
        "children": [
          {
            "type": "label",
            "name": "CostLabel",
            "id": "costLabel",
            "width": 180,
            "height": 28,
            "styleSlot": "deploy.label.cost"
          },
          {
            "type": "label",
            "name": "HintLabel",
            "id": "hintLabel",
            "width": 300,
            "height": 28,
            "styleSlot": "deploy.label.hint"
          }
        ]
      },
      {
        "type": "container",
        "name": "GhostImage",
        "id": "ghostImage",
        "width": 100,
        "height": 100,
        "active": false
      }
    ]
  },
  "validation": {
    "exceptions": {
      "no-empty-container": "GhostImage 為執行期動態填充容器，不需預設子節點"
    }
  }
}
