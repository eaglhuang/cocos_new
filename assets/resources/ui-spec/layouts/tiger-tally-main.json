          { "type": "label",  "name": "HpLabel3",      "id": "hpLabel3",      "widget": { "right": 6, "top": 6 },   "width": 56, "height": 20, "styleSlot": "tally.label.hp" },
          { "type": "image",  "name": "UnitTypeBadge3","id": "unitTypeBadge3","widget": { "left": 4, "bottom": 4 }, "width": 32, "height": 32, "skinSlot": "tally.badge.type" },
          { "type": "label",  "name": "UnitName3",     "id": "unitName3",     "widget": { "left": 40, "bottom": 10 }, "width": 110, "height": 18, "styleSlot": "tally.label.name" },
          { "type": "label",  "name": "CostBadge3",    "id": "costBadge3",    "widget": { "right": 6, "bottom": 6 }, "width": 28, "height": 28, "styleSlot": "tally.label.cost" },
          { "type": "image",  "name": "DisabledMask3", "id": "disabledMask3", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.disabled", "active": false }
        ]
      },
      {
        "type": "button",
        "name": "TallyCard4",
        "id": "tallyCard4",
        "width": "100%",
        "height": 160,
        "skinSlot": "tally.card.bg",
