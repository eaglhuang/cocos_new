          { "type": "label",  "name": "HpLabel2",      "id": "hpLabel2",      "widget": { "right": 6, "top": 6 },   "width": 56, "height": 20, "styleSlot": "tally.label.hp" },
          { "type": "image",  "name": "UnitTypeBadge2","id": "unitTypeBadge2","widget": { "left": 4, "bottom": 4 }, "width": 32, "height": 32, "skinSlot": "tally.badge.type" },
          { "type": "label",  "name": "UnitName2",     "id": "unitName2",     "widget": { "left": 40, "bottom": 10 }, "width": 110, "height": 18, "styleSlot": "tally.label.name" },
          { "type": "label",  "name": "CostBadge2",    "id": "costBadge2",    "widget": { "right": 6, "bottom": 6 }, "width": 28, "height": 28, "styleSlot": "tally.label.cost" },
          { "type": "image",  "name": "DisabledMask2", "id": "disabledMask2", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.disabled", "active": false }
        ]
