{
  "id": "tiger-tally-main",
  "version": 2,
  "_doc": "Zone 3: 虎符卡片區。左側螢幕，TopBar 下方，固定 4 張卡片。每張卡 160px 高；點擊任一卡片觸發 UnitInfoPanel 滑出。",
  "canvas": { "fitWidth": true, "fitHeight": true, "safeArea": true, "designWidth": 1920, "designHeight": 1080 },
  "root": {
    "type": "container",
    "name": "TigerTallyRoot",
    "id": "tigerTallyRoot",
    "widget": { "top": 88, "left": 0, "bottom": 0 },
    "width": "16%",
    "layout": { "type": "vertical", "spacing": 4, "paddingTop": 8, "paddingBottom": 8, "paddingLeft": 8, "paddingRight": 8 },
    "_doc": "寬度 16% ≈ 307px (@1920)。上接 TopBar(88px)，下接螢幕底部。",
    "children": [
      {
        "type": "button",
        "name": "TallyCard1",
        "id": "tallyCard1",
        "width": "100%",
        "height": 160,
        "skinSlot": "tally.card.bg",
        "_doc": "虎符卡 1（玩家目前上場武將的第1支兵種）",
        "children": [
          { "type": "image",  "name": "ArtBg1",       "id": "artBg1",        "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.art" },
          { "type": "image",  "name": "RarityBorder1", "id": "rarityBorder1", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.rarity.normal" },
          { "type": "label",  "name": "AtkLabel1",     "id": "atkLabel1",     "widget": { "left": 6, "top": 6 },    "width": 56, "height": 20, "styleSlot": "tally.label.atk", "_doc": "攻擊值：⚔N" },
          { "type": "label",  "name": "HpLabel1",      "id": "hpLabel1",      "widget": { "right": 6, "top": 6 },   "width": 56, "height": 20, "styleSlot": "tally.label.hp",  "_doc": "生命值：❤N" },
          { "type": "image",  "name": "UnitTypeBadge1","id": "unitTypeBadge1","widget": { "left": 4, "bottom": 4 }, "width": 32, "height": 32, "skinSlot": "tally.badge.type", "_doc": "兵種圓徽章 32×32" },
          { "type": "label",  "name": "UnitName1",     "id": "unitName1",     "widget": { "left": 40, "bottom": 10 }, "width": 110, "height": 18, "styleSlot": "tally.label.name" },
          { "type": "label",  "name": "CostBadge1",    "id": "costBadge1",    "widget": { "right": 6, "bottom": 6 }, "width": 28, "height": 28, "styleSlot": "tally.label.cost" },
          { "type": "image",  "name": "DisabledMask1", "id": "disabledMask1", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.disabled", "active": false }
        ]
      },
      {
        "type": "button",
        "name": "TallyCard2",
        "id": "tallyCard2",
        "width": "100%",
        "height": 160,
        "skinSlot": "tally.card.bg",
