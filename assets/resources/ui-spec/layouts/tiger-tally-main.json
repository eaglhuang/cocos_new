          { "type": "image",  "name": "RarityBorder4", "id": "rarityBorder4", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.rarity.normal" },
          { "type": "label",  "name": "AtkLabel4",     "id": "atkLabel4",     "widget": { "left": 6, "top": 6 },    "width": 56, "height": 20, "styleSlot": "tally.label.atk" },
          { "type": "label",  "name": "HpLabel4",      "id": "hpLabel4",      "widget": { "right": 6, "top": 6 },   "width": 56, "height": 20, "styleSlot": "tally.label.hp" },
          { "type": "image",  "name": "UnitTypeBadge4","id": "unitTypeBadge4","widget": { "left": 4, "bottom": 4 }, "width": 32, "height": 32, "skinSlot": "tally.badge.type" },
          { "type": "label",  "name": "UnitName4",     "id": "unitName4",     "widget": { "left": 40, "bottom": 10 }, "width": 110, "height": 18, "styleSlot": "tally.label.name" },
          { "type": "label",  "name": "CostBadge4",    "id": "costBadge4",    "widget": { "right": 6, "bottom": 6 }, "width": 28, "height": 28, "styleSlot": "tally.label.cost" },
          { "type": "image",  "name": "DisabledMask4", "id": "disabledMask4", "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 }, "skinSlot": "tally.card.disabled", "active": true,
            "_doc": "第4張卡預設冷卻中，active:true 顯示灰色遮罩" }
        ]
      }
    ]
  },
  "interactions": {
    "_doc": "TS 實作參考",
    "onCardClick": "TigerTallyPanel.ts 監聽各 tallyCard 的 Button.EventType.CLICK：傳入 cardIndex → 呼叫 onCardSelect(cardIndex, cardData)",
    "onCardSelect": "BattleScenePanel.ts 透過 tigerTallyPanel.onCardSelect = callback 接收 → 呼叫 unitInfoPanel.show(cardData)",
    "setCards": "TigerTallyPanel.setCards(cards: TallyCardData[]) 一次性重繪4張卡；cards.length < 4 的剩餘卡設為 disabled",
    "disabledState": "disabledMask active:true 時同步將對應 tallyCard 的 Button.interactable = false（仍可查看資訊）"
  }
}
