{
  "id": "action-command-main",
  "version": 2,
  "_doc": "Zone 7 v3: 奧義大圓（120px 含SP填充環，右下角錨點）+ 3個操作小圓（結束回合/計謀/單挑，80px，分布在大圓左/上/右）。點擊奧義且SP滿時彈出奧義選擇小窗。",
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080,
    "safeAreaConstrained": true
  },
  "root": {
    "type": "container",
    "name": "ActionCommandRoot",
    "widget": {
      "bottom": 18,
      "right": 18
    },
    "width": 246,
    "height": 226,
    "children": [
      {
        "type": "panel",
        "name": "CommandDockPlate",
        "widget": {
          "left": 0,
          "right": 0,
          "bottom": 0
        },
        "width": 246,
        "height": 142,
        "skinSlot": "action.dock.bg",
        "_doc": "右下指令底座，先以深色 plate 建立主從關係；之後若有正式美術可替換。"
      },
      {
        "type": "button",
        "name": "EndTurnBtn",
        "id": "endTurnBtn",
        "widget": {
          "top": 12,
          "left": 130
        },
        "width": 48,
        "height": 48,
        "skinSlot": "action.util.endturn",
        "_doc": "待機 / 結束回合屬低頻操作，縮為最小次級按鈕，放在操作群上方內側。",
        "children": [
          {
            "type": "image",
            "name": "EndTurnIcon",
            "id": "endTurnIcon",
            "widget": {
              "top": 6,
              "left": 15
            },
            "width": 18,
            "height": 18,
            "skinSlot": "action.icon.endturn",
            "_doc": "F8 command overlay glyph"
          },
          {
            "type": "label",
            "name": "EndTurnLabel",
            "widget": {
              "left": 4,
              "right": 4,
              "bottom": 4
            },
            "width": 40,
            "height": 16,
            "text": "待機",
            "styleSlot": "action.util.endturn.label"
          }
        ]
      },
      {
        "type": "button",
        "name": "UltimateBtn",
        "id": "ultimateBtn",
        "widget": {
          "left": 0,
          "bottom": 0
        },
        "width": 132,
        "height": 132,
        "skinSlot": "action.ultimate.bg",
        "_doc": "奧義主按鈕，保留為群組裡最大主操作圓盤。",
        "children": [
          {
            "type": "image",
            "name": "SpRing",
            "id": "spRing",
            "widget": {
              "top": -10,
              "bottom": -10,
              "left": -10,
              "right": -10
            },
            "skinSlot": "action.sp.ring",
            "_doc": "SP填充環（8px寬圓環）。TS透過 Sprite.fillRange(0.0~1.0) 控制，順時針填充。滿SP切換skin→action.sp.ring.ready"
          },
          {
            "type": "label",
            "name": "UltLabel",
            "id": "ultLabel",
            "width": 92,
            "height": 30,
            "styleSlot": "action.ultimate.label",
            "bind": "battle.ultName",
            "_doc": "SP未滿顯示'奧義'；SP滿顯示'發動'"
          },
          {
            "type": "label",
            "name": "SpPctLabel",
            "id": "spPctLabel",
            "width": 78,
            "height": 20,
            "styleSlot": "action.sp.pct.label",
            "bind": "battle.spPct",
            "_doc": "顯示'SP 75%'，SP滿時隱藏"
          }
        ]
      },
      {
        "type": "button",
        "name": "TacticsBtn",
        "id": "tacticsBtn",
        "widget": {
          "right": 68,
          "bottom": 8
        },
        "width": 82,
        "height": 82,
        "skinSlot": "action.util.tactics",
        "_doc": "中頻操作 1：計謀，配置於主按鈕右側。",
        "children": [
          {
            "type": "image",
            "name": "TacticsIcon",
            "id": "tacticsIcon",
            "widget": {
              "top": 14,
              "left": 27
            },
            "width": 28,
            "height": 28,
            "skinSlot": "action.icon.tactics",
            "_doc": "F8 command overlay glyph"
          },
          {
            "type": "label",
            "name": "TacticsLabel",
            "widget": {
              "left": 10,
              "right": 10,
              "bottom": 10
            },
            "width": 50,
            "height": 18,
            "text": "計謀",
            "styleSlot": "action.util.label"
          }
        ]
      },
      {
        "type": "button",
        "name": "DuelBtn",
        "id": "duelBtn",
        "widget": {
          "right": 0,
          "bottom": 8
        },
        "width": 82,
        "height": 82,
        "skinSlot": "action.util.duel",
        "_doc": "中頻操作 2：單挑，與計謀共同形成主按鈕右側雙次鍵。",
        "children": [
          {
            "type": "image",
            "name": "DuelIcon",
            "id": "duelIcon",
            "widget": {
              "top": 14,
              "left": 27
            },
            "width": 28,
            "height": 28,
            "skinSlot": "action.icon.duel",
            "_doc": "F8 command overlay glyph"
          },
          {
            "type": "label",
            "name": "DuelLabel",
            "widget": {
              "left": 10,
              "right": 10,
              "bottom": 10
            },
            "width": 50,
            "height": 18,
            "text": "單挑",
            "styleSlot": "action.util.label"
          }
        ]
      },
      {
        "type": "container",
        "name": "UltimatePopup",
        "id": "ultimatePopup",
        "widget": {
          "left": 8,
          "bottom": 146
        },
        "width": 220,
        "height": 0,
        "skinSlot": "action.popup.bg",
        "active": false,
        "_doc": "奧義技能選擇彈窗。SP滿時點擊大圓觸發 → active:true + Tween高度展開(技能數×56+16)。點擊外部關閉。",
        "children": []
      }
    ]
  },
  "interactions": {
    "_doc": "TS實作參考",
    "onEndTurnClick": "ActionCommandPanel.ts 監聽 EndTurnBtn.click → emit endTurn 事件（BattleScene 接收）",
    "onTacticsClick": "ActionCommandPanel.ts 監聽 TacticsBtn.click → emit tactics 事件",
    "onDuelClick": "ActionCommandPanel.ts 監聽 DuelBtn.click → emit GeneralDuelChallenge 全域事件",
    "spUpdate": "BattleManager 廣播 SP_CHANGED → ActionCommandPanel 更新 spRing 填充值、ultLabel 文字",
    "onUltimateClick": "SP>=100% → 開啟 UltimatePopup（由TS動態填充技能項目）；SP<100% → toast '奧義蓄力中'"
  }
}
