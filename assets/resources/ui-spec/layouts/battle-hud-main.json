{
  "id": "battle-hud-main",
  "version": 1,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "BattleHUDRoot",
    "widget": {
      "top": 0,
      "left": 0,
      "right": 0,
      "bottom": 0
    },
    "children": [
      {
        "type": "panel",
        "name": "TopBar",
        "widget": {
          "top": 0,
          "left": 0,
          "right": 0
        },
        "height": 112,
        "skinSlot": "hud.topbar.bg",
        "children": [
          {
            "type": "panel",
            "name": "PlayerInfoPlate",
            "widget": {
              "top": 10,
              "left": 18
            },
            "width": 468,
            "height": 86,
            "skinSlot": "hud.topbar.plate"
          },
          {
            "type": "panel",
            "name": "CenterInfoPlate",
            "widget": {
              "top": 10,
              "hCenter": 0
            },
            "width": 452,
            "height": 86,
            "skinSlot": "hud.topbar.plate"
          },
          {
            "type": "panel",
            "name": "EnemyInfoPlate",
            "widget": {
              "top": 10,
              "right": 18
            },
            "width": 468,
            "height": 86,
            "skinSlot": "hud.topbar.plate"
          },
          {
            "type": "container",
            "name": "PlayerSide",
            "widget": {
              "top": 20,
              "left": 30
            },
            "width": 432,
            "height": 72,
            "layout": {
              "type": "horizontal",
              "spacing": 14
            },
            "children": [
              {
                "type": "image",
                "name": "PlayerPortrait",
                "id": "playerPortrait",
                "width": 72,
                "height": 72,
                "skinSlot": "hud.portrait.player",
                "interactable": true
              },
              {
                "type": "label",
                "name": "PlayerName",
                "id": "playerName",
                "width": 156,
                "height": 32,
                "styleSlot": "hud.label.name",
                "bind": "battleState.playerName"
              },
              {
                "type": "label",
                "name": "PlayerFortressLabel",
                "id": "playerFortressLabel",
                "width": 168,
                "height": 36,
                "styleSlot": "hud.label.hp",
                "bind": "battleState.playerFortressHp"
              }
            ]
          },
          {
            "type": "container",
            "name": "CenterInfo",
            "widget": {
              "top": 20,
              "hCenter": 0
            },
            "width": 360,
            "height": 86,
            "layout": {
              "type": "vertical",
              "spacing": 2
            },
            "children": [
              {
                "type": "panel",
                "name": "SceneGambitBadgeDock",
                "id": "sceneGambitBadgeDock",
                "widget": { "hCenter": 0 },
                "width": 168,
                "height": 18,
                "active": false,
                "skinSlot": "hud.summary.card",
                "children": [
                  {
                    "type": "label",
                    "name": "SceneGambitBadgeLabel",
                    "id": "sceneGambitBadgeLabel",
                    "widget": { "hCenter": 0, "vCenter": 0 },
                    "width": 168,
                    "height": 18,
                    "text": "場景戰法",
                    "styleSlot": "hud.label.sceneGambitBadge"
                  }
                ]
              },
              {
                "type": "label",
                "name": "TurnLabel",
                "id": "turnLabel",
                "width": 360,
                "height": 24,
                "styleSlot": "hud.label.round",
                "text": "第 1 回合",
                "bind": "battleState.turnCount"
              },
              {
                "type": "label",
                "name": "FoodLabel",
                "id": "foodLabel",
                "width": 360,
                "height": 18,
                "styleSlot": "hud.label.food",
                "text": "🌾 糧草 20/20",
                "bind": "battleState.food"
              },
              {
                "type": "label",
                "name": "StatusLabel",
                "id": "statusLabel",
                "width": 360,
                "height": 18,
                "styleSlot": "hud.label.status",
                "text": "準備中",
                "bind": "battleState.statusMessage"
              }
            ]
          },
          {
            "type": "container",
            "name": "EnemySide",
            "widget": {
              "top": 20,
              "right": 30
            },
            "width": 432,
            "height": 72,
            "layout": {
              "type": "horizontal",
              "spacing": 14
            },
            "children": [
              {
                "type": "label",
                "name": "EnemyFortressLabel",
                "id": "enemyFortressLabel",
                "width": 168,
                "height": 36,
                "styleSlot": "hud.label.hp.enemy",
                "bind": "battleState.enemyFortressHp"
              },
              {
                "type": "label",
                "name": "EnemyName",
                "id": "enemyName",
                "width": 156,
                "height": 32,
                "styleSlot": "hud.label.name.enemy",
                "bind": "battleState.enemyName"
              },
              {
                "type": "image",
                "name": "EnemyPortrait",
                "id": "enemyPortrait",
                "width": 72,
                "height": 72,
                "skinSlot": "hud.portrait.enemy",
                "interactable": true
              }
            ]
          }
        ]
      },
      {
        "type": "panel",
        "name": "FortressBarsPlate",
        "widget": {
          "top": 112,
          "left": 24,
          "right": 24
        },
        "height": 44,
        "skinSlot": "hud.topbar.plate"
      },
      {
        "type": "container",
        "name": "ProgressBars",
        "widget": {
          "top": 118,
          "left": 36,
          "right": 36
        },
        "height": 34,
        "layout": {
          "type": "horizontal",
          "spacing": 8
        },
        "children": [
          {
            "type": "label",
            "name": "PlayerFortressTitle",
            "text": "我軍陣地",
            "width": "11%",
            "height": 34,
            "styleSlot": "hud.label.fortress.player"
          },
          {
            "type": "image",
            "name": "PlayerFortressBar",
            "id": "playerFortressBar",
            "width": "30%",
            "skinSlot": "hud.bar.hp"
          },
          {
            "type": "label",
            "name": "VsLabel",
            "text": "VS",
            "width": "12%",
            "height": 34,
            "styleSlot": "hud.label.vs"
          },
          {
            "type": "image",
            "name": "EnemyFortressBar",
            "id": "enemyFortressBar",
            "width": "30%",
            "skinSlot": "hud.bar.hp.enemy"
          },
          {
            "type": "label",
            "name": "EnemyFortressTitle",
            "text": "敵軍陣地",
            "width": "11%",
            "height": 34,
            "styleSlot": "hud.label.fortress.enemy"
          }
        ]
      },
      {
        "type": "panel",
        "name": "StrategistSummaryBand",
        "active": false,
        "widget": {
          "top": 166,
          "left": 24,
          "right": 24
        },
        "height": 76,
        "skinSlot": "hud.summary.card",
        "children": [
          {
            "type": "label",
            "name": "StrategistSummaryTitle",
            "widget": { "top": 12, "left": 18 },
            "width": 148,
            "height": 20,
            "text": "軍師摘要",
            "styleSlot": "hud.label.summaryTitle"
          },
          {
            "type": "label",
            "name": "StrategistSummaryBody",
            "widget": { "top": 34, "left": 18, "right": 606, "bottom": 12 },
            "text": "危險因子與配置缺口在此摘要，只揭露對策方向，不直接交答案。",
            "styleSlot": "hud.label.summaryBody"
          },
          {
            "type": "label",
            "name": "StageSalvageTitle",
            "widget": { "top": 12, "right": 298 },
            "width": 120,
            "height": 20,
            "text": "戰後回收",
            "styleSlot": "hud.label.summaryTitle"
          },
          {
            "type": "label",
            "name": "StageSalvageBody",
            "widget": { "top": 34, "right": 18, "width": 400, "bottom": 12 },
            "text": "僅提示可帶出的物資與線索，不在戰中直接改寫帳號經濟。",
            "styleSlot": "hud.label.summaryBodyRight"
          }
        ]
      },
      {
        "_comment": "SP moved to Zone 7 UltimateBtn ring; BottomRight panel removed in v3"
      }
    ]
  }
}
