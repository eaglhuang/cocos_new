{
  "id": "battle-hud-main",
  "version": 1,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "BattleHUDRoot",
    "widget": {
      "top": 0,
      "left": 0,
      "right": 0,
      "bottom": 0
    },
    "children": [
      {
        "type": "panel",
        "name": "TopBar",
        "widget": {
          "top": 0,
          "left": 0,
          "right": 0
        },
        "height": 88,
        "skinSlot": "hud.topbar.bg",
        "children": [
          {
            "type": "container",
            "name": "PlayerSide",
            "widget": {
              "top": 12,
              "left": 24
            },
            "width": 420,
            "height": 64,
            "layout": {
              "type": "horizontal",
              "spacing": 12
            },
            "children": [
              {
                "type": "image",
                "name": "PlayerPortrait",
                "id": "playerPortrait",
                "width": 64,
                "height": 64,
                "skinSlot": "hud.portrait.player",
                "interactable": true
              },
              {
                "type": "label",
                "name": "PlayerName",
                "id": "playerName",
                "width": 128,
                "height": 28,
                "styleSlot": "hud.label.name",
                "bind": "battleState.playerName"
              },
              {
                "type": "label",
                "name": "PlayerFortressLabel",
                "id": "playerFortressLabel",
                "width": 140,
                "height": 36,
                "styleSlot": "hud.label.hp",
                "bind": "battleState.playerFortressHp"
              }
            ]
          },
          {
            "type": "container",
            "name": "CenterInfo",
            "width": 360,
            "height": 64,
            "layout": {
              "type": "vertical",
              "spacing": 4
            },
            "children": [
              {
                "type": "label",
                "name": "TurnLabel",
                "id": "turnLabel",
                "width": 360,
                "height": 28,
                "styleSlot": "hud.label.round",
                "text": "第 1 回合",
                "bind": "battleState.turnCount"
              },
              {
                "type": "label",
                "name": "FoodLabel",
                "id": "foodLabel",
                "width": 360,
                "height": 24,
                "styleSlot": "hud.label.food",
                "text": "🌾 糧草 20/20",
                "bind": "battleState.food"
              },
              {
                "type": "label",
                "name": "StatusLabel",
                "id": "statusLabel",
                "width": 360,
                "height": 24,
                "styleSlot": "hud.label.status",
                "text": "準備中",
                "bind": "battleState.statusMessage"
              }
            ]
          },
          {
            "type": "container",
            "name": "EnemySide",
            "widget": {
              "top": 12,
              "right": 24
            },
            "width": 420,
            "height": 64,
            "layout": {
              "type": "horizontal",
              "spacing": 12
            },
            "children": [
              {
                "type": "label",
                "name": "EnemyFortressLabel",
                "id": "enemyFortressLabel",
                "width": 140,
                "height": 36,
                "styleSlot": "hud.label.hp.enemy",
                "bind": "battleState.enemyFortressHp"
              },
              {
                "type": "label",
                "name": "EnemyName",
                "id": "enemyName",
                "width": 128,
                "height": 28,
                "styleSlot": "hud.label.name.enemy",
                "bind": "battleState.enemyName"
              },
              {
                "type": "image",
                "name": "EnemyPortrait",
                "id": "enemyPortrait",
                "width": 64,
                "height": 64,
                "skinSlot": "hud.portrait.enemy",
                "interactable": true
              }
            ]
          }
        ]
      },
      {
        "type": "container",
        "name": "ProgressBars",
        "widget": {
          "top": 88,
          "left": 24,
          "right": 24
        },
        "height": 32,
        "layout": {
          "type": "horizontal",
          "spacing": 6
        },
        "children": [
          {
            "type": "label",
            "name": "PlayerFortressTitle",
            "text": "我軍陣地",
            "width": "9%",
            "height": 32,
            "styleSlot": "hud.label.fortress.player"
          },
          {
            "type": "image",
            "name": "PlayerFortressBar",
            "id": "playerFortressBar",
            "width": "36%",
            "skinSlot": "hud.bar.hp"
          },
          {
            "type": "label",
            "name": "VsLabel",
            "text": "VS",
            "width": "10%",
            "height": 32,
            "styleSlot": "hud.label.vs"
          },
          {
            "type": "image",
            "name": "EnemyFortressBar",
            "id": "enemyFortressBar",
            "width": "36%",
            "skinSlot": "hud.bar.hp.enemy"
          },
          {
            "type": "label",
            "name": "EnemyFortressTitle",
            "text": "敵軍陣地",
            "width": "9%",
            "height": 32,
            "styleSlot": "hud.label.fortress.enemy"
          }
        ]
      },
      {
        "_comment": "SP moved to Zone 7 UltimateBtn ring; BottomRight panel removed in v3"
      }
    ]
  }
}