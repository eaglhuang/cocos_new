{
  "id": "general-detail-bloodline-v3-main",
  "version": 18,
  "validation": {
    "exceptions": {
      "no-empty-container": "StoryStrip 六格為 master art overlay slot，故意保留空容器供後續 overlay / runtime 對位使用。"
    }
  },
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "GeneralDetailBloodlineRoot",
    "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
    "children": [
      {
        "type": "image",
        "name": "BackgroundScene",
        "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
        "skinSlot": "gdv3.bg.scene"
      },
      { "$ref": "fragments/layouts/gdv3-portrait-carrier" },
      {
        "type": "container",
        "name": "OverviewStateChrome",
        "widget": { "top": 82, "left": 82 },
        "width": 184,
        "height": 28,
        "children": [
          {
            "type": "label",
            "name": "PortraitModeHint",
            "width": 184,
            "height": 28,
            "styleSlot": "gdv3.label.mode"
          }
        ]
      },
      {
        "type": "container",
        "name": "InfoCardChrome",
        "widget": { "top": 40, "right": 114 },
        "width": "48.6%",
        "height": "70.2%",
        "children": [
          {
            "type": "image",
            "name": "InfoCardFill",
            "widget": { "top": 10, "bottom": 10, "left": 10, "right": 10 },
            "skinSlot": "gdv3.info.card.fill"
          }
        ]
      },
      {
        "type": "container",
        "name": "InfoContent",
        "widget": { "top": 42, "right": 136 },
        "width": "44.8%",
        "height": "65.8%",
        "children": [
          {
            "type": "container",
            "name": "HeaderUnderlay",
            "widget": { "top": 14, "left": 18, "right": 18 },
            "height": 104,
            "children": [
              {
                "type": "image",
                "name": "HeaderUnderlayFill",
                "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
                "skinSlot": "gdv3.header.band"
              }
            ]
          },
          { "$ref": "fragments/layouts/gdv3-header-row" },
          { "$ref": "fragments/layouts/gdv3-overview-summary-modules" },
          { "$ref": "fragments/layouts/gdv3-bloodline-overview-modules" }
        ]
      },
      {
        "type": "container",
        "name": "StoryStripRail",
        "widget": { "left": 0, "right": 0, "bottom": 0 },
        "height": 182,
        "children": [
          {
            "type": "image",
            "name": "StoryStripBleed",
            "widget": { "top": -4, "bottom": -4, "left": -4, "right": -4 },
            "skinSlot": "gdv3.story.rail.bleed"
          },
          {
            "type": "image",
            "name": "StoryStripFill",
            "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
            "skinSlot": "gdv3.story.rail"
          },
          {
            "type": "image",
            "name": "StoryStripFrame",
            "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
            "skinSlot": "gdv3.story.rail.frame"
          }
        ]
      },
      {
        "type": "image",
        "name": "StoryStripArt",
        "widget": { "left": 24, "right": 24, "bottom": 16 },
        "height": 148,
        "skinSlot": "gdv3.story.art"
      },
      { "$ref": "fragments/layouts/gdv3-story-strip" }
    ]
  }
}