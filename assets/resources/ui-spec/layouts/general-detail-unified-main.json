{
  "id": "general-detail-unified-main",
  "version": 1,
  "canvas": {
    "fitWidth": true,
    "fitHeight": true,
    "safeArea": true,
    "safeAreaConstrained": true,
    "designWidth": 1920,
    "designHeight": 1080
  },
  "root": {
    "type": "container",
    "name": "GeneralDetailRoot",
    "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
    "transition": { "enter": "scaleIn", "exit": "scaleOut", "duration": 0.2, "easing": "backOut" },
    "children": [
      {
        "type": "image",
        "name": "BackgroundFull",
        "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 }
      },
      {
        "type": "button",
        "name": "TopCloseBtn",
        "id": "topCloseBtn",
        "widget": { "top": 28, "right": 28 },
        "width": 88,
        "height": 88,
        "skinSlot": "detail.back.circle",
        "children": [
          { "type": "label", "name": "BackArrow", "widget": { "left": 0, "right": 0, "top": 24 }, "height": 28, "styleSlot": "detail.label.backArrow", "text": "←" },
          { "type": "label", "name": "BackLabel", "widget": { "left": 10, "right": 10, "bottom": 23 }, "height": 11, "styleSlot": "detail.label.backCaption", "text": "返回" }
        ]
      },
      {
        "type": "panel",
        "name": "ClickBlocker",
        "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
        "skinSlot": "detail.blockInput"
      },
      {
        "type": "image",
        "name": "PortraitImage",
        "widget": { "left": 0, "bottom": 0 },
        "width": "62%",
        "height": "100%",
        "skinSlot": "general.portrait.placeholder"
      },
      {
        "type": "image",
        "name": "PortraitRarityBadge",
        "widget": { "top": 82, "left": 18 },
        "width": 96,
        "height": 150,
        "skinSlot": "gdv3.portrait.rarityBadge",
        "zIndex": 40
      },
      {
        "type": "container",
        "name": "RightTabBar",
        "widget": { "top": 150, "bottom": 20, "right": 16 },
        "width": 160,
        "layout": { "type": "vertical", "spacing": 20, "paddingTop": 0, "paddingBottom": 0, "paddingLeft": 10, "paddingRight": 16 },
        "children": [
          {
            "type": "button",
            "name": "BtnTabOverview",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.overview",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "將" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "GEN" }
            ]
          },
          {
            "type": "button",
            "name": "BtnTabStats",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.stats",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "屬" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "STAT" }
            ]
          },
          {
            "type": "button",
            "name": "BtnTabTactics",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.skills",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "技" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "TACT" }
            ]
          },
          {
            "type": "button",
            "name": "BtnTabBloodline",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.bloodline",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "命" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "FATE" }
            ]
          },
          {
            "type": "button",
            "name": "BtnTabEquip",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.basics",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "寶" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "GEAR" }
            ]
          },
          {
            "type": "button",
            "name": "BtnTabAptitude",
            "width": 128,
            "height": 128,
            "skinSlot": "detail.tab.circle.aptitude",
            "children": [
              { "type": "label", "name": "Label", "widget": { "left": 10, "right": 10, "top": 39 }, "height": 32, "styleSlot": "detail.label.circleTabMain", "text": "適" },
              { "type": "label", "name": "EnLabel", "widget": { "left": 10, "right": 10, "bottom": 39 }, "height": 12, "styleSlot": "detail.label.circleTabLabel", "text": "APT" }
            ]
          }
        ]
      },
      {
        "type": "container",
        "name": "RightContentArea",
        "widget": { "top": 50, "bottom": 56, "right": 176 },
        "width": 540,
        "children": [
          {
            "type": "container",
            "name": "OverviewSlot",
            "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
            "active": false,
            "children": [
              { "type": "spacer", "name": "OverviewSlotAnchor", "width": 1, "height": 1 }
            ],
            "lazySlot": true,
            "defaultFragment": "fragments/layouts/gd-tab-overview",
            "childType": "GeneralDetailOverviewChild"
          },
          {
            "type": "container",
            "name": "ContentSlot",
            "widget": { "top": 0, "bottom": 0, "left": 0, "right": 0 },
            "children": [
              { "type": "spacer", "name": "ContentSlotAnchor", "width": 1, "height": 1 }
            ],
            "lazySlot": true,
            "defaultFragment": "fragments/layouts/gd-tab-overview",
            "childType": "GeneralDetailOverviewChild"
          }
        ]
      }
    ]
  }
}
