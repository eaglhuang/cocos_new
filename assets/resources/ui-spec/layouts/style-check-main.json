{
  "id": "style-check-main",
  "version": 1,
  "canvas": { "fitWidth": true, "fitHeight": true, "designWidth": 1920, "designHeight": 1080 },
  "root": {
    "type": "container",
    "name": "StyleSandboxRoot",
    "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 },
    "children": [
      {
        "type": "panel",
        "name": "Background",
        "widget": { "top": 0, "left": 0, "right": 0, "bottom": 0 },
        "skinSlot": "sandbox.main_bg"
      },
      {
        "type": "panel",
        "name": "MainContainer",
        "id": "mainContainer",
        "width": "90%",
        "height": "90%",
        "layout": { "type": "vertical", "spacing": 24, "paddingTop": 40, "paddingBottom": 40, "paddingLeft": 40, "paddingRight": 40 },
        "children": [
          { "type": "label", "name": "Title", "width": "100%", "height": 60, "textKey": "ui.style_check.title", "styleSlot": "sandbox.label.headline" },
          {
            "type": "panel",
            "name": "RarityRow",
            "width": "100%",
            "height": 100,
            "layout": { "type": "horizontal", "spacing": 16 },
            "children": [
              { "type": "panel", "name": "White", "width": 80, "height": 80, "skinSlot": "rarity.white" },
              { "type": "panel", "name": "Green", "width": 80, "height": 80, "skinSlot": "rarity.green" },
              { "type": "panel", "name": "Blue", "width": 80, "height": 80, "skinSlot": "rarity.blue" },
              { "type": "panel", "name": "Purple", "width": 80, "height": 80, "skinSlot": "rarity.purple" },
              { "type": "panel", "name": "Gold", "width": 80, "height": 80, "skinSlot": "rarity.gold" },
              { "type": "panel", "name": "Red", "width": 80, "height": 80, "skinSlot": "rarity.red" },
              { "type": "panel", "name": "Rainbow", "width": 80, "height": 80, "skinSlot": "rarity.rainbow" }
            ]
          },
          {
              "type": "panel",
              "name": "ButtonRow",
              "width": "100%",
              "height": 60,
              "layout": { "type": "horizontal", "spacing": 24 },
              "children": [
                  { "type": "button", "name": "BtnPrimary", "width": 200, "height": 56, "skinSlot": "sandbox.button.primary", "textKey": "ui.style_check.primary" },
                  { "type": "button", "name": "BtnSecondary", "width": 200, "height": 56, "skinSlot": "sandbox.button.secondary", "textKey": "ui.style_check.secondary" },
                  { "type": "button", "name": "BtnParchment", "width": 200, "height": 56, "skinSlot": "sandbox.button.parchment", "textKey": "ui.style_check.parchment" }
              ]
          },
          { "type": "label", "name": "BodyText", "width": "80%", "height": 100, "textKey": "ui.style_check.lorem", "styleSlot": "sandbox.label.body" }
        ]
      }
    ]
  }
}
