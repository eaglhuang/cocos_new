{
  "id": "dialog-confirm-default",
  "version": 1,
  "bundle": "ui_common",
  "atlasPolicy": "ui_common",
  "slots": {
    "widget.overlay.mask": {
      "kind": "color",
      "color": "colorBlack",
      "alpha": 180
    },
    "widget.dialog.card.bg": {
      "kind": "color",
      "color": "surfaceNavy",
      "alpha": 238,
      "spriteType": "sliced",
      "border": [12, 12, 12, 12]
    },
    "widget.header.bg": {
      "kind": "color",
      "color": "surfaceNavyHigh",
      "alpha": 255
    },
    "widget.header.title": {
      "kind": "label-style",
      "fontSize": 28,
      "color": "secondary",
      "isBold": true,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER"
    },
    "widget.header.close.btn": {
      "kind": "button-skin",
      "normal": "ui-spec/placeholders/btn_close_normal",
      "pressed": "ui-spec/placeholders/btn_close_pressed",
      "disabled": "ui-spec/placeholders/btn_close_disabled",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "widget.text.body": {
      "kind": "label-style",
      "fontSize": 22,
      "color": "textMidGray",
      "horizontalAlign": "LEFT",
      "verticalAlign": "TOP"
    },
    "widget.btn.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [12, 12, 12, 12],
      "allowAutoAtlas": true
    },
    "widget.btn.secondary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [12, 12, 12, 12],
      "allowAutoAtlas": true
    }
  }
}
