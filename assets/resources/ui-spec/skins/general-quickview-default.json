{
  "id": "general-quickview-default",
  "version": 1,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_hud",
  "_doc": "主將屬性快覽彈窗皮膚。深藍底，金色邊框，水墨風。",
  "slots": {
    "quickview.bg": {
      "kind": "color",
      "color": "backgroundNavy",
      "alpha": 245,
      "_doc": "彈窗主背景，圓角12px，金色邊框1px",
      "spriteType": "sliced",
      "border": [12, 12, 12, 12]
    },
    "quickview.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "quickview.overlay": {
      "kind": "color",
      "color": "colorBlack",
      "alpha": 80,
      "_doc": "全螢幕半透明遮罩，點擊關閉"
    },
    "quickview.header.bg": {
      "kind": "color",
      "color": "surfaceNavyDark",
      "alpha": 220
    },
    "quickview.section.bg": {
      "kind": "color",
      "color": "surfaceNavyDeepest",
      "alpha": 200
    },
    "quickview.portrait": {
      "kind": "sprite-frame",
      "path": "sprites/battle/portrait_player_placeholder/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_fallback": "#3A8FD9",
      "_doc": "由TS動態替換成對應武將頭像"
    },
    "quickview.btn.close": {
      "kind": "color",
      "color": "surfaceNavyMid",
      "alpha": 200
    },
    "quickview.label.name": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "secondaryLight",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "quickview.label.title": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textKhaki",
      "horizontalAlign": "LEFT"
    },
    "quickview.label.faction": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 13,
      "lineHeight": 16,
      "color": "textSteelMid",
      "horizontalAlign": "LEFT"
    },
    "quickview.label.stat": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textSteelLight",
      "horizontalAlign": "LEFT"
    },
    "quickview.label.section": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 13,
      "lineHeight": 16,
      "color": "secondary",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "quickview.label.skill": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 13,
      "lineHeight": 17,
      "color": "textSteelLight",
      "horizontalAlign": "LEFT",
      "overflow": "shrink"
    },
    "quickview.label.close": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "textHintGray",
      "horizontalAlign": "CENTER",
      "isBold": true
    }
  }
}
