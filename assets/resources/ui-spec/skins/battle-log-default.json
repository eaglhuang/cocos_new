{
  "id": "battle-log-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_ui",
  "slots": {
    "log.root.bg": {
      "kind": "color",
      "color": "surfaceInkBlue",
      "alpha": 156
    },
    "log.header.bg": {
      "kind": "color",
      "color": "backgroundNavyAlt",
      "alpha": 188
    },
    "log.btn.toggle": {
      "kind": "color",
      "color": "secondary",
      "alpha": 200,
      "spriteType": "sliced",
      "border": [4, 4, 4, 4]
    },
    "log.btn.auto": {
      "kind": "color",
      "color": "surfaceGreenDeep",
      "alpha": 180,
      "_doc": "Auto 自動戰鬥按鈕，32×32"
    },
    "log.btn.speed": {
      "kind": "color",
      "color": "surfaceBlueDeep",
      "alpha": 180,
      "_doc": "x2 加速按鈕，32×32"
    },
    "log.btn.setting": {
      "kind": "color",
      "color": "surfaceMidGray",
      "alpha": 180,
      "_doc": "⚙ 設定按鈕，32×32"
    },
    "log.btn.collapse": {
      "kind": "color",
      "color": "surfaceSepiaDeep",
      "alpha": 170,
      "_doc": "📋 收合/展開日誌按鈕，全寬 28px"
    },
    "log.icon.auto": {
      "kind": "sprite-frame",
      "path": "sprites/battle/log_icon_auto/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true
    },
    "log.icon.speed": {
      "kind": "sprite-frame",
      "path": "sprites/battle/log_icon_speed/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true
    },
    "log.icon.setting": {
      "kind": "sprite-frame",
      "path": "sprites/battle/log_icon_setting/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true
    },
    "log.icon.collapse": {
      "kind": "sprite-frame",
      "path": "sprites/battle/log_icon_collapse/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true
    },
    "log.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 15,
      "lineHeight": 20,
      "color": "secondaryLight",
      "isBold": true,
      "overflow": "CLAMP",
      "horizontalAlign": "LEFT"
    },
    "log.label.toggle": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textWarmGold",
      "horizontalAlign": "CENTER"
    },
    "log.label.content": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 12,
      "lineHeight": 18,
      "color": "textSteelLight",
      "overflow": "RESIZE_HEIGHT"
    },
    "log.label.btn": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 12,
      "lineHeight": 16,
      "color": "rarityWhite",
      "horizontalAlign": "CENTER"
    }
  }
}
