{
  "id": "battle-log-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_ui",
  "slots": {
    "log.root.bg": {
      "kind": "color",
      "color": "surfaceCharcoal",
      "alpha": 205
    },
    "log.root.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "log.header.bg": {
      "kind": "color",
      "color": "surfaceCharcoalBlue",
      "alpha": 235
    },
    "log.btn.toggle": {
      "kind": "color",
      "color": "secondary",
      "alpha": 200,
      "spriteType": "sliced",
      "border": [4, 4, 4, 4]
    },
    "log.btn.auto": {
      "kind": "color",
      "color": "surfaceGreenDeep",
      "alpha": 220,
      "_doc": "Auto 自動戰鬥按鈕，32×32"
    },
    "log.btn.speed": {
      "kind": "color",
      "color": "surfaceBlueDeep",
      "alpha": 220,
      "_doc": "x2 加速按鈕，32×32"
    },
    "log.btn.setting": {
      "kind": "color",
      "color": "surfaceMidGray",
      "alpha": 220,
      "_doc": "⚙ 設定按鈕，32×32"
    },
    "log.btn.collapse": {
      "kind": "color",
      "color": "surfaceInkBlue",
      "alpha": 200,
      "_doc": "📋 收合/展開日誌按鈕，全寬 28px"
    },
    "log.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "textPrimary",
      "isBold": true,
      "overflow": "CLAMP",
      "horizontalAlign": "LEFT"
    },
    "log.label.toggle": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textKhaki",
      "horizontalAlign": "CENTER"
    },
    "log.label.content": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 13,
      "lineHeight": 18,
      "color": "textLightGray",
      "overflow": "RESIZE_HEIGHT"
    },
    "log.label.btn": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 12,
      "lineHeight": 16,
      "color": "rarityWhite",
      "horizontalAlign": "CENTER"
    }
  }
}
