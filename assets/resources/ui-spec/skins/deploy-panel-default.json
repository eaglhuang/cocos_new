{
  "id": "deploy-panel-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_ui",
  "slots": {
    "deploy.slot.card": {
      "kind": "color",
      "color": "surfaceDeepBlue",
      "alpha": 230,
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "deploy.label.troop": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "secondary",
      "isBold": true,
      "overflow": "CLAMP"
    },
    "deploy.label.cost": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 15,
      "lineHeight": 19,
      "color": "secondaryLight",
      "overflow": "CLAMP"
    },
    "deploy.label.hint": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 13,
      "lineHeight": 17,
      "color": "textDarkGray",
      "overflow": "CLAMP"
    },
    "deploy.action.button": {
      "kind": "color",
      "color": "surfaceDeepBlue",
      "alpha": 200,
      "spriteType": "sliced",
      "border": [6, 6, 6, 6]
    },
    "deploy.action.button.endTurn": {
      "kind": "color",
      "color": "surfaceDeepBlue",
      "alpha": 180,
      "spriteType": "sliced",
      "border": [6, 6, 6, 6]
    },
    "deploy.label.action": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 20,
      "lineHeight": 24,
      "color": "onPrimary",
      "isBold": false,
      "overflow": "CLAMP"
    }
  }
}
