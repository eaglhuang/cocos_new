{
  "id": "spirit-tally-detail-default",
  "version": 1,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby",
  "$fragments": ["header-rarity-plaque-default"],
  "slots": {
    "widget.header.plaque.base": { "kind": "color-rect", "color": "surfaceDeep", "alpha": 224 },
    "widget.header.plaque.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/detail_header_fill", "spriteType": "simple", "allowAutoAtlas": true, "opacity": 0.92 },
    "widget.header.plaque.band": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/formal/header_band_formal", "spriteType": "sliced", "border": [20, 0, 20, 0], "allowAutoAtlas": true, "opacity": 0.42 },
    "widget.header.plaque.title": { "kind": "label-style", "fontSize": 28, "lineHeight": 30, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.subtitle": { "kind": "label-style", "fontSize": 16, "lineHeight": 18, "color": "accentGold", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.badge.underlay": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.9 },
    "widget.header.plaque.badge.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.96 },
    "widget.header.plaque.badge.label": { "kind": "label-style", "fontSize": 22, "lineHeight": 24, "color": "colorWhite", "outlineWidth": 1, "outlineColor": "outlineHeavy", "horizontalAlign": "CENTER" },
    "std.bg.full": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/detail_content_bg", "spriteType": "sliced", "border": [96, 360, 96, 420], "allowAutoAtlas": false },
    "std.card.main": { "kind": "sprite-frame", "path": "ui-spec/placeholders/bg_ink_detail", "spriteType": "sliced", "border": [96, 96, 96, 96], "allowAutoAtlas": false },
    "std.panel.spirit-card": { "kind": "color-rect", "color": "stdPanelSpiritCard", "alpha": 234 },
    "std.panel.summary": { "kind": "color-rect", "color": "stdPanelSummary", "alpha": 230 },
    "std.panel.module": { "kind": "color-rect", "color": "stdPanelModule", "alpha": 238 },
    "std.panel.elite-troop": { "kind": "color-rect", "color": "stdPanelEliteTroop", "alpha": 238 },
    "std.art.spirit-card": { "kind": "color-rect", "color": "stdArtSpiritCard", "alpha": 204 },
    "std.art.hero-ghost": { "kind": "color-rect", "color": "stdArtHeroGhost", "alpha": 170 },
    "std.crest": { "kind": "color-rect", "color": "stdCrestColor", "alpha": 208 },
    "std.art.troop-banner": { "kind": "color-rect", "color": "stdArtTroopBanner", "alpha": 216 },
    "std.art.troop-unit": { "kind": "color-rect", "color": "stdArtTroopUnit", "alpha": 210 },
    "std.art.troop-crest": { "kind": "color-rect", "color": "stdArtTroopCrest", "alpha": 208 },
    "std.button.primary": { "kind": "color-rect", "color": "stdButtonPrimary" },
    "std.button.secondary": { "kind": "color-rect", "color": "stdButtonSecondary" },
    "std.badge.lock": { "kind": "color-rect", "color": "stdBadgeLock", "alpha": 204 },
    "std.label.name": { "kind": "label-style", "fontSize": 38, "lineHeight": 44, "color": "stdLabelName", "horizontalAlign": "LEFT" },
    "std.label.title": { "kind": "label-style", "fontSize": 28, "lineHeight": 34, "color": "stdLabelTitle", "horizontalAlign": "LEFT" },
    "std.label.rank": { "kind": "label-style", "fontSize": 22, "lineHeight": 24, "color": "stdLabelRank", "horizontalAlign": "CENTER", "outlineWidth": 1, "outlineColor": "outlineHeavy" },
    "std.label.button": { "kind": "label-style", "fontSize": 20, "lineHeight": 24, "color": "stdLabelButton", "horizontalAlign": "CENTER", "verticalAlign": "CENTER" }
  }
}
