{
  "id": "shop-main-default",
  "version": 5,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby_ui",
  "$fragments": ["item-cell-default", "common-parchment-default"],
  "slots": {
    "shop.bg": {
      "kind": "sprite-frame",
      "path": "sprites/lobby/bg_shop/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": false,
      "comment": "大面積背景圖，不進 Auto Atlas"
    },
    "shop.titlebar.bg": {
      "kind": "color",
      "color": "backgroundDeep",
      "alpha": 220
    },
    "shop.tabs.bg": {
      "kind": "color",
      "color": "backgroundMid",
      "alpha": 200
    },
    "parchment.bg.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "parchment.bg.noise": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/noise/paper_noise_256",
      "spriteType": "tiled",
      "opacity": 0.10,
      "blendMode": "alpha"
    },
    "parchment.bg.accent": {
      "kind": "color-rect",
      "color": "transparent"
    },
    "shop.content.carrier": {
      "kind": "color-rect",
      "color": "surfaceParchmentFill",
      "alpha": 230,
      "comment": "D-2 QA anchor: MainContainer parchment light-surface carrier，對應 parchment-panel fragment 的 parchment.bg.fill"
    },
    "shop.tabs.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "shop.tab.btn": {
      "kind": "color",
      "color": "surfaceNavy",
      "alpha": 0,
      "spriteType": "sliced",
      "border": [4, 4, 4, 4]
    },
    "shop.btn.close": {
      "kind": "color",
      "color": "surfaceControl",
      "alpha": 180,
      "spriteType": "sliced",
      "border": [6, 6, 6, 6]
    },
    "shop.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 28,
      "lineHeight": 34,
      "color": "secondary",
      "isBold": true,
      "overflow": "CLAMP",
      "horizontalAlign": "LEFT"
    },
    "shop.label.resource": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "secondaryLight",
      "overflow": "CLAMP"
    },
    "shop.label.tab": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "textPrimary",
      "overflow": "CLAMP",
      "horizontalAlign": "CENTER"
    },
    "ui-common-metal.commerce.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "shop.button.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    }
  }
}
