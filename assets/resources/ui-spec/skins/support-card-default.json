{
  "id": "support-card-default",
  "version": 2,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby_support_card",
  "description": "支援卡系統 skin：主列表、卡片格子、詳情頁（四頁籤）、編組預覽、突破UI",

  "slots": {

    "topbar.btn.back": {
      "kind": "button-skin",
      "normal":   "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed":  "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true,
      "note": "舊 support_card 專用 back button 已失效，先回落到 shared secondary family；若要恢復明確 back glyph，需另補 dedicated icon slot。"
    },
    "topbar.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 34,
      "color": "secondaryLight",
      "horizontalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "topbar.btn.borrow": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "tab.toggle": {
      "kind": "toggle-style",
      "normal_bg":   "#1A1A1A",
      "selected_bg": "#2A2010",
      "normal_text_color":   "#99907C",
      "selected_text_color": "#FFE088",
      "fontSize": 22,
      "border_bottom_selected": { "color": "secondary", "thickness": 3 }
    },

    "filterbar.btn.filter": {
      "kind": "button-skin",
      "normal": "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed": "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "filterbar.label.sort": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "textSecondary"
    },

    "card.bg.rarity": {
      "kind": "sprite-9slice",
      "note": "根據 card.rarity 動態換圖：SSR=bg_card_ssr / SR=bg_card_sr / R=bg_card_r",
      "frames": {
        "SSR": "ui/support_card/bg_card_ssr",
        "SR":  "ui/support_card/bg_card_sr",
        "R":   "ui/support_card/bg_card_r"
      },
      "border": [12,12,12,12]
    },
    "card.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "card.portrait": {
      "kind": "sprite-frame",
      "note": "動態 → 由 Support_Template 對應圖片路徑 ui/portraits/support/{template_id}"
    },
    "card.star": {
      "kind": "sprite-frame",
      "frame": "ui/support_card/icon_star_filled"
    },
    "card.star.empty": {
      "kind": "sprite-frame",
      "frame": "ui/support_card/icon_star_empty"
    },
    "card.label.name": {
      "kind": "label-style",
      "fontSize": 22,
      "color": "textPrimary",
      "horizontalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "card.overlay.lock": {
      "kind": "color-rect",
      "color": "colorBlack",
      "opacity": 0.5
    },
    "card.label.lock": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "textMuted",
      "horizontalAlign": "CENTER"
    },

    "ui-common-metal.commerce.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "bottombar.btn.gacha": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "bottombar.label.gacha": {
      "kind": "label-style",
      "fontSize": 24,
      "color": "textOnParchment"
    },
    "bottombar.btn.team": {
      "kind": "button-skin",
      "normal": "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed": "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "detail.tab.effects": {
      "kind": "toggle-style",
      "normal_bg":   "#1A1A1A",
      "selected_bg": "#20201F",
      "normal_text_color":   "#99907C",
      "selected_text_color": "#FFE088",
      "fontSize": 22
    },
    "detail.tab.events": { "$ref": "detail.tab.effects" },
    "detail.tab.story":  { "$ref": "detail.tab.effects" },

    "detail.star.active": {
      "kind": "sprite-frame",
      "frame": "ui/support_card/icon_star_filled_lg"
    },
    "detail.star.locked": {
      "kind": "sprite-frame",
      "frame": "ui/support_card/icon_star_locked"
    },

    "detail.event.row.unlocked": {
      "kind": "color-rect",
      "color": "surfaceContainer"
    },
    "detail.event.row.locked": {
      "kind": "color-rect",
      "color": "backgroundOlive"
    },
    "detail.event.label.locked": {
      "kind": "label-style",
      "fontSize": 18,
      "color": "outline"
    },
    "detail.event.label.skill": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "textPrimary",
      "overflow": "SHRINK"
    },
    "detail.event.icon.lock": {
      "kind": "sprite-frame",
      "frame": "ui/common/icon_lock"
    },
    "detail.event.label.starReq": {
      "kind": "label-style",
      "fontSize": 16,
      "color": "secondary"
    },

    "breakthrough.btn.confirm": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "breakthrough.btn.fragment": {
      "kind": "button-skin",
      "normal": "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed": "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "borrow.card.bg": {
      "kind": "sprite-9slice",
      "frame": "ui/support_card/bg_card_borrow",
      "border": [12,12,12,12]
    },
    "borrow.label.owner": {
      "kind": "label-style",
      "fontSize": 18,
      "color": "textSecondary"
    },

    "synergy.badge": {
      "kind": "sprite-frame",
      "frame": "ui/support_card/badge_synergy"
    },
    "synergy.label": {
      "kind": "label-style",
      "fontSize": 18,
      "color": "tertiaryLight"
    }
  },

  "validation": {
    "requiredSlots": [
      "card.bg.rarity", "card.portrait", "card.star", "card.star.empty",
      "card.label.name", "bottombar.btn.gacha", "bottombar.btn.team",
      "detail.event.icon.lock"
    ],
    "nineSliceIntegerCheck": [
      "card.bg.rarity", "breakthrough.btn.confirm",
      "bottombar.btn.gacha"
    ]
  }
}
