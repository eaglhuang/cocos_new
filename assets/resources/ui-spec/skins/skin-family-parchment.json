{
  "id": "skin-family-parchment",
  "version": 1,
  "bundle": "ui_common",
  "atlasPolicy": "ui_family_parchment",
  "description": "parchment family 共用 slot。說明卡、日誌頁、文字密集型容器的框體家族。themeStack family 層使用。",
  "slots": {
    "frame.parchment.edge": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/parchment/frame_edge/spriteFrame",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8],
      "bleed": 3,
      "allowAutoAtlas": true
    },
    "frame.parchment.bleed": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/parchment/frame_bleed/spriteFrame",
      "spriteType": "sliced",
      "border": [14, 14, 14, 14],
      "bleed": 8,
      "opacity": 0.55,
      "blendMode": "alpha",
      "allowAutoAtlas": true
    },
    "frame.parchment.fill": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/parchment/frame_fill/spriteFrame",
      "spriteType": "sliced",
      "border": [6, 6, 6, 6],
      "allowAutoAtlas": true
    },
    "frame.parchment.seal": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/parchment/seal_ornament/spriteFrame",
      "spriteType": "simple",
      "opacity": 0.7,
      "blendMode": "multiply",
      "allowAutoAtlas": true
    },
    "frame.parchment.label": {
      "kind": "label-style",
      "color": "#2D2926",
      "fontSize": 24,
      "lineHeight": 32,
      "isBold": false,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "frame.parchment.label.title": {
      "kind": "label-style",
      "color": "#4a2800",
      "fontSize": 30,
      "lineHeight": 38,
      "isBold": true,
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER"
    },
    "frame.parchment.label.muted": {
      "kind": "label-style",
      "color": "#6B5E4E",
      "fontSize": 18,
      "lineHeight": 24,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    }
  }
}
