{
  "id": "elite-troop-codex-default",
  "version": 2,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby",
  "$fragments": ["common-parchment-default", "header-rarity-plaque-default"],
  "slots": {
    "etc.bg.full": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/general_detail/detail_content_bg",
      "spriteType": "sliced",
      "border": [96, 360, 96, 420],
      "allowAutoAtlas": false
    },
    "etc.panel.side": { "kind": "color-rect", "color": "surfaceDeep", "alpha": 232 },
    "etc.panel.main": { "kind": "color-rect", "color": "stdPanelModule", "alpha": 224 },
    "etc.panel.detail": { "kind": "color-rect", "color": "stdPanelEliteTroop", "alpha": 238 },
    "etc.panel.module": { "kind": "color-rect", "color": "stdPanelModule", "alpha": 238 },
    "etc.card.troop": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/general_detail/v3_final/module_card_panel_mint_rect_v1",
      "spriteType": "sliced",
      "border": [20, 24, 20, 24],
      "allowAutoAtlas": true,
      "opacity": 0.98
    },
    "etc.card.troop.selected": {
      "kind": "color-rect",
      "color": "accentGold",
      "alpha": 64
    },
    "etc.art.banner": { "kind": "color-rect", "color": "stdArtTroopBanner", "alpha": 216 },
    "etc.art.crest": { "kind": "color-rect", "color": "stdArtTroopCrest", "alpha": 204 },
    "widget.header.plaque.base": { "kind": "color-rect", "color": "surfaceDeep", "alpha": 224 },
    "widget.header.plaque.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/detail_header_fill", "spriteType": "simple", "allowAutoAtlas": true, "opacity": 0.92 },
    "widget.header.plaque.band": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/formal/header_band_formal", "spriteType": "sliced", "border": [20, 0, 20, 0], "allowAutoAtlas": true, "opacity": 0.42 },
    "widget.header.plaque.title": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 34, "lineHeight": 36, "color": "text.parchment.primary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "widget.header.plaque.subtitle": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 15, "lineHeight": 18, "color": "accent.gold.base", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "widget.header.plaque.badge.underlay": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.9 },
    "widget.header.plaque.badge.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.96 },
    "widget.header.plaque.badge.label": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 18, "lineHeight": 22, "color": "colorWhite", "outlineWidth": 1, "outlineColor": "outlineHeavy", "horizontalAlign": "CENTER", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.rail.title": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 24, "lineHeight": 28, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.rail.body": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 15, "lineHeight": 20, "color": "text.parchment.secondary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.meta": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 14, "lineHeight": 18, "color": "accent.gold.base", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.badge": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 16, "lineHeight": 18, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "CENTER", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.quality": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 22, "lineHeight": 24, "color": "accent.gold.base", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.card.title": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 20, "lineHeight": 24, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.card.subtitle": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 16, "lineHeight": 20, "color": "accent.gold.base", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.card.meta": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 14, "lineHeight": 18, "color": "secondary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.card.body": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 14, "lineHeight": 18, "color": "text.parchment.secondary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "TOP", "overflow": "SHRINK" },
    "etc.label.detail.title": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 28, "lineHeight": 32, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK", "isBold": true },
    "etc.label.detail.subtitle": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 18, "lineHeight": 22, "color": "accent.gold.base", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.detail.meta": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 15, "lineHeight": 18, "color": "secondary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "CENTER", "overflow": "SHRINK" },
    "etc.label.detail.body": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 16, "lineHeight": 21, "color": "text.parchment.primary", "outlineWidth": 0, "horizontalAlign": "LEFT", "verticalAlign": "TOP", "overflow": "SHRINK" },
    "std.button.primary": { "kind": "color-rect", "color": "stdButtonPrimary" },
    "std.button.secondary": { "kind": "color-rect", "color": "stdButtonSecondary" },
    "std.label.button": { "kind": "label-style", "font": "fonts/notosans_tc/font", "fontSize": 20, "lineHeight": 24, "color": "stdLabelButton", "outlineWidth": 0, "horizontalAlign": "CENTER", "verticalAlign": "CENTER", "overflow": "SHRINK" }
  }
}
