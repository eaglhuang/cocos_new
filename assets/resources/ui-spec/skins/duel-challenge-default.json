{
  "id": "duel-challenge-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_ui",
  "slots": {
    "duel.root.bg": {
      "kind": "color",
      "color": "background",
      "alpha": 235,
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "duel.root.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.header.bg": {
      "kind": "color",
      "color": "surface",
      "alpha": 255
    },
    "ui-common-metal.equipment.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.btn.accept": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "ui-common-paper.utility.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.btn.reject": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 20,
      "lineHeight": 26,
      "color": "secondaryLight",
      "isBold": true,
      "overflow": "CLAMP",
      "horizontalAlign": "CENTER"
    },
    "duel.label.score": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "textPrimary",
      "overflow": "CLAMP"
    },
    "duel.label.btn": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "background",
      "isBold": true,
      "horizontalAlign": "CENTER"
    },
    "duel.label.hint": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textHintBlue",
      "overflow": "CLAMP"
    },
    "widget.overlay.mask": {
      "kind": "color",
      "color": "colorBlack",
      "alpha": 180
    },
    "widget.dialog.card.bg": {
      "kind": "color",
      "color": "background",
      "alpha": 235,
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "widget.header.bg": {
      "kind": "color",
      "color": "surface",
      "alpha": 255
    },
    "widget.header.title": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "secondaryLight",
      "isBold": true,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER"
    },
    "widget.header.close.btn": {
      "kind": "button-skin",
      "normal": "ui-spec/placeholders/btn_close_normal",
      "pressed": "ui-spec/placeholders/btn_close_pressed",
      "disabled": "ui-spec/placeholders/btn_close_disabled",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "widget.text.body": {
      "kind": "label-style",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "textPrimary",
      "horizontalAlign": "LEFT",
      "verticalAlign": "TOP"
    },
    "widget.btn.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "widget.btn.secondary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    }
  }
}
