{
  "id": "duel-challenge-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_ui",
  "slots": {
    "duel.root.bg": {
      "kind": "color",
      "color": "#0F0F0F",
      "alpha": 235,
      "spriteType": "sliced",
      "border": [8, 8, 8, 8]
    },
    "duel.root.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.header.bg": {
      "kind": "color",
      "color": "#1A1A1A",
      "alpha": 255
    },
    "ui-common-metal.equipment.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.btn.accept": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "ui-common-paper.utility.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.btn.reject": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/paper_utility/btn_primary_normal",
      "pressed": "sprites/ui_families/common/paper_utility/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/paper_utility/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "duel.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 20,
      "lineHeight": 26,
      "color": "#FFE088",
      "isBold": true,
      "overflow": "CLAMP",
      "horizontalAlign": "CENTER"
    },
    "duel.label.score": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "#E5E2E1",
      "overflow": "CLAMP"
    },
    "duel.label.btn": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "#0F0F0F",
      "isBold": true,
      "horizontalAlign": "CENTER"
    }
  }
}
