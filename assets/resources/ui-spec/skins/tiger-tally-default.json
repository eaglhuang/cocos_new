{
  "id": "tiger-tally-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "tiger_tally",
  "_doc": "虎符卡片區皮膚。水墨+鋼鐵主題：深色底板、金色稀有度框、兵種標章。",
  "slots": {
    "tally.card.bg": {
      "kind": "color-rect",
      "color": "surfaceTeal",
      "alpha": 236,
      "_doc": "保留給 debug 白模使用的基礎色塊卡面；正式 BattleScene 會改掛 tally.card.bg.hard。"
    },
    "tally.card.bg.hard": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/006/spriteFrame",
      "spriteType": "sliced",
      "border": [60, 60, 60, 60],
      "bleed": 2,
      "allowAutoAtlas": true,
      "_fallback": "#1A1208",
      "_doc": "虎符卡面硬版主框核心（006 母框拆件）。第三輪加厚 border，讓 title plaque、left chip、bottom stars 都落在主框內部的視覺包覆範圍。"
    },
    "tally.card.frame.full": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_full_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "SSR 母框完整參考版。主要用於對位與美術檢查，不建議直接作為 runtime 拉伸件。"
    },
    "tally.card.frame.core": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/006/spriteFrame",
      "spriteType": "sliced",
      "border": [60, 60, 60, 60],
      "allowAutoAtlas": true,
      "_doc": "006 母框的 stretch-safe 外框核心。第三輪以更厚的 9-slice 包覆 title 與 star band。"
    },
    "tally.card.frame.titlePlaque": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_title_plaque_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "上方標題牌匾 overlay，獨立回貼，避免跟外框一起拉伸。"
    },
    "tally.card.frame.leftChip": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_left_chip_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "左側小 chip / cost 承載件，獨立 overlay。"
    },
    "tally.card.frame.rarityBadgePlaque": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_rarity_badge_plaque_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "稀有度 badge / crest 承載牌。可供 rarity / star 視覺模組掛載。"
    },
    "tally.card.frame.sideRail.dark": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_side_rail_dark_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "右側窄 dark carrier。對齊參考圖後改回較長的內嵌結構，承接徽記與功能 icon 區。"
    },
    "tally.card.frame.sideRail.amber": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_side_rail_amber_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "右側上端短 amber cap / seat overlay。僅保留短上帽，與下方 dark carrier 形成更接近參考圖的連續輪廓。"
    },
    "tally.card.frame.bottomBand": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/frame-parts/ssr/tally_frame_bottom_band_ssr/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "底部中央 band overlay，承接 grain cost / set / status 小圖。"
    },
    "tally.card.art": {
      "kind": "sprite-frame",
      "path": "ui/tiger-tally/card-art/troops/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": false,
      "_fallback": "#2A3040"
    },
    "tally.card.topShade": {
      "kind": "color-rect",
      "color": "#09111BCC",
      "_doc": "卡片頂部資訊遮罩，讓名稱與角標在大頭像上保持可讀。"
    },
    "tally.card.statBar": {
      "kind": "color-rect",
      "color": "#071018D9",
      "_doc": "卡片底部數值條，參考戰場英雄卡的底部數值區。"
    },
    "tally.card.costPlate": {
      "kind": "color-rect",
      "color": "#0E1824E0",
      "_doc": "右上糧草小角標，降低體積但保留一眼可讀。"
    },
    "tally.card.rarity.normal": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_normal/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#6E7A8A"
    },
    "tally.card.rarity.rare": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_rare/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#D4AF37"
    },
    "tally.card.rarity.epic": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_epic/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#A855F7"
    },
    "tally.card.disabled": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_card_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [0, 0, 0, 0],
      "allowAutoAtlas": true,
      "_fallback": "#000000",
      "_fallbackOpacity": 160,
      "_doc": "冷卻遮罩：半透明黑色疊加，含冷卻 icon（由TS動態添加Label顯示回合數）"
    },
    "tally.badge.type": {
      "kind": "sprite-frame",
      "path": "sprites/battle/battle_unit_type_underlay/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "兵種符頭像：cavalry/infantry/archer/pike/shield/engineer。TS 依 TroopType 切換不同 spriteFrame。"
    },
    "tally.label.rarity": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 13,
      "lineHeight": 15,
      "color": "#FFE28A",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "稀有度標籤，顯示於左上角六角形牌匾（SSR/SR/R/N）。TS 在 _populateCards 中將 rarity enum 映射為顯示文字。"
    },
    "tally.label.stars": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 14,
      "lineHeight": 16,
      "color": "#FFD36A",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": false,
      "_doc": "星數顯示，放在底部 band 中心（★★★）。bind tally[i].stars，TS 需填入對應 rarity 的星字串。"
    },
    "widget.resource.icon": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "#F6D37A",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "資源 icon 用的 glyph 樣式，供糧草符號或同類資源 glyph 使用。"
    },
    "tally.label.atk": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 24,
      "lineHeight": 26,
      "color": "#7EC4FF",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "底部左側主數值，改成偏戰術藍，接近參考圖的側欄資訊節奏。"
    },
    "tally.label.hp": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 24,
      "lineHeight": 26,
      "color": "#C4F7C3",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "底部右側主數值，使用高亮薄荷綠提高生存資訊辨識。"
    },
    "tally.label.name": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 20,
      "lineHeight": 22,
      "color": "#F7FAFF",
      "horizontalAlign": "CENTER",
      "isBold": true,
      "overflow": "truncate",
      "_doc": "名稱退成頂部輔助資訊，讓頭像與底部數值成為第一視線。"
    },
    "tally.label.sub": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 12,
      "lineHeight": 14,
      "color": "#A6B8CA",
      "horizontalAlign": "LEFT",
      "overflow": "truncate",
      "_doc": "特殊部隊副標，補足這是戰術單位卡而非武將卡的辨識。"
    },
    "tally.label.stats": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 17,
      "color": "textCoolGray",
      "horizontalAlign": "LEFT"
    },
    "tally.label.cost": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "#F6D37A",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "糧草費用縮小成右上角標，避免跟卡片主體搶權重。"
    },
    "tally.label.badge": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "colorWhite",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
      "isBold": true,
      "_doc": "兵種徽章縮寫文字（CV/IN/AR/SH...），白色置中，由 Layout JSON 定義，TigerTallyPanel 只負責填入文字。lineHeight 必須 >= fontSize 避免 Cocos 裁切。"
    }
  }
}
