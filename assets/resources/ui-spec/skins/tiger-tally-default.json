{
  "id": "tiger-tally-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "tiger_tally",
  "_doc": "虎符卡片區皮膚。水墨+鋼鐵主題：深色底板、金色稀有度框、兵種標章。",
  "slots": {
    "tally.card.bg": {
      "kind": "color-rect",
      "color": "surfaceTeal",
      "alpha": 236,
      "_doc": "保留給 debug 白模使用的基礎色塊卡面；正式 BattleScene 會改掛 tally.card.bg.hard。"
    },
    "tally.card.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "tally.card.bg.hard": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_card_bg_hard/spriteFrame",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8],
      "bleed": 2,
      "allowAutoAtlas": true,
      "_fallback": "#1A1208",
      "_doc": "虎符卡面硬版：暖鐵棕底板 + 金色邊框，更貼近實體軍牌質感"
    },
    "tally.card.art": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_card_art_placeholder/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_fallback": "#2A3040"
    },
    "tally.card.topShade": {
      "kind": "color-rect",
      "color": "#09111BCC",
      "_doc": "卡片頂部資訊遮罩，讓名稱與角標在大頭像上保持可讀。"
    },
    "tally.card.statBar": {
      "kind": "color-rect",
      "color": "#071018D9",
      "_doc": "卡片底部數值條，參考戰場英雄卡的底部數值區。"
    },
    "tally.card.costPlate": {
      "kind": "color-rect",
      "color": "#0E1824E0",
      "_doc": "右上糧草小角標，降低體積但保留一眼可讀。"
    },
    "tally.card.rarity.normal": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_normal/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#6E7A8A"
    },
    "tally.card.rarity.rare": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_rare/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#D4AF37"
    },
    "tally.card.rarity.epic": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_rarity_epic/spriteFrame",
      "spriteType": "sliced",
      "border": [4, 4, 4, 4],
      "allowAutoAtlas": true,
      "_fallback": "#A855F7"
    },
    "tally.card.disabled": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_card_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [0, 0, 0, 0],
      "allowAutoAtlas": true,
      "_fallback": "#000000",
      "_fallbackOpacity": 160,
      "_doc": "冷卻遮罩：半透明黑色疊加，含冷卻 icon（由TS動態添加Label顯示回合數）"
    },
    "tally.badge.type": {
      "kind": "sprite-frame",
      "path": "sprites/battle/tally_badge_type/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "兵種符頭像：cavalry/infantry/archer/pike/shield/engineer。TS 依 TroopType 切換不同 spriteFrame。"
    },
    "tally.label.atk": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 24,
      "lineHeight": 26,
      "color": "#7EC4FF",
      "horizontalAlign": "LEFT",
      "isBold": true,
      "_doc": "底部左側主數值，改成偏戰術藍，接近參考圖的側欄資訊節奏。"
    },
    "tally.label.hp": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 24,
      "lineHeight": 26,
      "color": "#C4F7C3",
      "horizontalAlign": "RIGHT",
      "isBold": true,
      "_doc": "底部右側主數值，使用高亮薄荷綠提高生存資訊辨識。"
    },
    "tally.label.name": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 20,
      "lineHeight": 22,
      "color": "#F7FAFF",
      "horizontalAlign": "LEFT",
      "isBold": true,
      "overflow": "truncate",
      "_doc": "名稱退成頂部輔助資訊，讓頭像與底部數值成為第一視線。"
    },
    "tally.label.sub": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 12,
      "lineHeight": 14,
      "color": "#A6B8CA",
      "horizontalAlign": "LEFT",
      "overflow": "truncate",
      "_doc": "特殊部隊副標，補足這是戰術單位卡而非武將卡的辨識。"
    },
    "tally.label.stats": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 17,
      "color": "textCoolGray",
      "horizontalAlign": "LEFT"
    },
    "tally.label.cost": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "#F6D37A",
      "horizontalAlign": "CENTER",
      "isBold": true,
      "_doc": "糧草費用縮小成右上角標，避免跟卡片主體搶權重。"
    },
    "tally.label.badge": {
      "kind": "label-style",
      "font": "fonts/manrope/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "colorWhite",
      "horizontalAlign": "CENTER",
      "isBold": true,
      "_doc": "兵種徽章縮寫文字（CV/IN/AR/SH...），白色置中，由 Layout JSON 定義，TigerTallyPanel 只負責填入文字。lineHeight 必須 >= fontSize 避免 Cocos 裁切。"
    }
  }
}
