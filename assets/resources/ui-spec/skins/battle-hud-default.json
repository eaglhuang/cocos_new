{
  "id": "battle-hud-default",
  "version": 2,
  "bundle": "battle_ui",
  "atlasPolicy": "battle_hud",
  "slots": {
    "hud.topbar.bg": {
      "kind": "sprite-frame",
      "path": "sprites/battle/topbar_bg/spriteFrame",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "bleed": 4,
      "allowAutoAtlas": true
    },
    "hud.topbar.plate": {
      "kind": "sprite-frame",
      "path": "sprites/battle/topbar_bg/spriteFrame",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "bleed": 4,
      "allowAutoAtlas": true
    },
    "hud.summary.card": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/parchment/frame",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "allowAutoAtlas": true,
      "opacity": 0.92
    },
    "hud.bar.hp": {
      "kind": "sprite-frame",
      "path": "sprites/battle/bar_hp_player/spriteFrame",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8],
      "allowAutoAtlas": true
    },
    "hud.bar.hp.enemy": {
      "kind": "sprite-frame",
      "path": "sprites/battle/bar_hp_enemy/spriteFrame",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8],
      "allowAutoAtlas": true
    },
    "hud.portrait.player": {
      "kind": "sprite-frame",
      "path": "sprites/generals/avatars/cao_cao_avatar/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": false,
      "_fallback": "#3A8FD9",
      "$note": "初始顯示曹操頭像；BattleScene 呼叫 setPlayerGeneralId 後由 BattleHUDComposite._applyPortrait 替換為當場武將頭像"
    },
    "hud.portrait.enemy": {
      "kind": "sprite-frame",
      "path": "sprites/generals/avatars/lu_bu_avatar/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": false,
      "_fallback": "#D94A3A",
      "$note": "初始顯示呂布頭像；BattleScene 呼叫 setEnemyGeneralId 後由 BattleHUDComposite._applyPortrait 替換為當場武將頭像"
    },
    "hud.label.name": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "textSteelLighter",
      "horizontalAlign": "LEFT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.name.enemy": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "primaryLight",
      "horizontalAlign": "RIGHT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.round": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 22,
      "lineHeight": 24,
      "color": "secondaryLight",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineDark",
      "outlineWidth": 2
    },
    "hud.label.food": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 15,
      "lineHeight": 18,
      "color": "textWarmGold",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.hp": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "secondaryLight",
      "horizontalAlign": "LEFT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 3
    },
    "hud.label.hp.enemy": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "primaryLight",
      "horizontalAlign": "RIGHT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 3
    },
    "hud.label.status": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 16,
      "lineHeight": 18,
      "color": "textCyanLight",
      "horizontalAlign": "CENTER",
      "overflow": "SHRINK",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.sceneGambitBadge": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 16,
      "color": "textWarmGold",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.summaryTitle": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 15,
      "lineHeight": 18,
      "color": "secondaryLight",
      "horizontalAlign": "LEFT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.summaryBody": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textSteelLighter",
      "horizontalAlign": "LEFT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2,
      "overflow": "SHRINK"
    },
    "hud.label.summaryBodyRight": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 18,
      "color": "textSteelLighter",
      "horizontalAlign": "RIGHT",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2,
      "overflow": "SHRINK"
    },
    "hud.label.fortress.player": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 20,
      "color": "textCyan",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    },
    "hud.label.vs": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 24,
      "color": "secondaryLight",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineDark",
      "outlineWidth": 2
    },
    "hud.label.fortress.enemy": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 14,
      "lineHeight": 20,
      "color": "primaryLight",
      "horizontalAlign": "CENTER",
      "outlineColor": "outlineHeavy",
      "outlineWidth": 2
    }
  }
}
