    "widget.header.plaque.badge.label": { "kind": "label-style", "fontSize": 9, "lineHeight": 12, "color": "colorWhite", "outlineWidth": 1, "outlineColor": "outlineHeavy", "horizontalAlign": "CENTER" },

    "gacha.bg.pool": {
      "kind": "sprite-frame",
      "note": "按池子切換：hero=bg_pool_hero_jpg / support=bg_pool_support_jpg / limited=bg_pool_limited_jpg，需維持 JPG 以避免 UI 穿透",
      "frames": {
        "hero":    "sprites/ui_families/general_detail/generated/general_detail_bg_v5_civil",
        "support": "sprites/ui_families/general_detail/generated/general_detail_bg_v5_civil",
        "limited": "sprites/ui_families/general_detail/generated/general_detail_bg_v5_civil"
      }
    },
    "gacha.preview.bg.full": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/gacha/generated/gacha_preview_bg_full"
    },
    "gacha.banner.art.full": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/gacha/generated/gacha_preview_bg_full"
    },
    "gacha.banner.hero.guan_yu": {
      "kind": "sprite-frame",
      "path": "sprites/generals/guan_yu_portrait",
      "spriteType": "simple"
    },
    "gacha.banner.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },

    "gacha.btn.back": {
      "kind": "button-skin",
      "normal":   "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed":  "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "gacha.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 34,
      "color": "secondaryLight",
      "horizontalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "gacha.btn.destiny_shop": {
      "kind": "button-skin",
      "normal":   "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed":  "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "gacha.tab.toggle": {
      "kind": "toggle-style",
      "normal_bg":            { "color": "backgroundOlive", "opacity": 0.85 },
      "selected_bg":          { "color": "surfaceOliveDark", "opacity": 1.0 },
      "normal_text_color":    "#99907C",
      "selected_text_color":  "#FFE088",
      "border_bottom_selected": { "color": "secondary", "thickness": 3 },
      "fontSize": 22
