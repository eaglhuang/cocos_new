{
  "id": "gacha-default",
  "version": 3,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby_gacha",
  "$fragments": ["item-cell-default", "common-parchment-default"],
  "description": "轉蛋系統 skin：主畫面、卡池分頁、抽卡按鈕、結果頁、天命商店",

  "slots": {

    "widget.header.plaque.base": { "kind": "color-rect", "color": "surfaceDeep", "alpha": 224 },
    "widget.header.plaque.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/detail_header_fill", "spriteType": "simple", "allowAutoAtlas": true, "opacity": 0.92 },
    "widget.header.plaque.band": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/formal/header_band_formal", "spriteType": "sliced", "border": [20, 0, 20, 0], "allowAutoAtlas": true, "opacity": 0.42 },
    "widget.header.plaque.title": { "kind": "label-style", "font": "fonts/newsreader/font", "fontSize": 28, "lineHeight": 30, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.subtitle": { "kind": "label-style", "fontSize": 16, "lineHeight": 18, "color": "secondary", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.badge.underlay": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.9 },
    "widget.header.plaque.badge.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.96 },
    "widget.header.plaque.badge.label": { "kind": "label-style", "fontSize": 22, "lineHeight": 24, "color": "colorWhite", "outlineWidth": 1, "outlineColor": "outlineHeavy", "horizontalAlign": "CENTER" },

    "gacha.bg.pool": {
      "kind": "sprite-frame",
      "note": "按池子切換：hero=bg_pool_hero / support=bg_pool_support / limited=bg_pool_limited",
      "frames": {
        "hero":    "ui/gacha/bg_pool_hero",
        "support": "ui/gacha/bg_pool_support",
        "limited": "ui/gacha/bg_pool_limited"
      }
    },
    "gacha.banner.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },

    "gacha.btn.back": {
      "kind": "button-skin",
      "normal":   "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed":  "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "gacha.label.title": {
      "kind": "label-style",
      "font": "fonts/newsreader/font",
      "fontSize": 34,
      "color": "secondaryLight",
      "horizontalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "gacha.btn.destiny_shop": {
      "kind": "button-skin",
      "normal":   "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed":  "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "gacha.tab.toggle": {
      "kind": "toggle-style",
      "normal_bg":            { "color": "backgroundOlive", "opacity": 0.85 },
      "selected_bg":          { "color": "surfaceOliveDark", "opacity": 1.0 },
      "normal_text_color":    "#99907C",
      "selected_text_color":  "#FFE088",
      "border_bottom_selected": { "color": "secondary", "thickness": 3 },
      "fontSize": 22
    },

    "gacha.banner.art": {
      "kind": "sprite-frame",
      "note": "由 Pool_ID 決定 Banner 圖片路徑 ui/gacha/banner_{pool_id}"
    },
    "gacha.label.featured": {
      "kind": "label-style",
      "fontSize": 22,
      "color": "secondaryLight",
      "outlineColor": "textOnParchment",
      "outlineWidth": 2
    },
    "gacha.badge.rateup": {
      "kind": "sprite-9slice",
      "frame": "ui/gacha/badge_rateup",
      "border": [8,8,8,8]
    },
    "gacha.label.timer": {
      "kind": "label-style",
      "fontSize": 18,
      "color": "warning",
      "overflow": "SHRINK"
    },

    "gacha.label.pity_small": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "tertiaryLight",
      "overflow": "SHRINK"
    },
    "gacha.label.pity_big": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "secondary",
      "overflow": "SHRINK"
    },

    "gacha.btn.rate_info": {
      "kind": "button-skin",
      "normal":  "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed": "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },

    "currency.icon.spirit_jade": {
      "kind": "sprite-frame",
      "frame": "ui/currency/icon_spirit_jade"
    },
    "currency.icon.bronze_charm": {
      "kind": "sprite-frame",
      "frame": "ui/currency/icon_bronze_charm"
    },
    "currency.label.count": {
      "kind": "label-style",
      "fontSize": 22,
      "color": "textPrimary",
      "overflow": "SHRINK"
    },
    "gacha.btn.add_currency": {
      "kind": "button-skin",
      "normal":  "sprites/common/btn_secondary_normal/spriteFrame",
      "pressed": "sprites/common/btn_secondary_pressed/spriteFrame",
      "disabled": "sprites/common/btn_secondary_disabled/spriteFrame",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true,
      "note": "舊 add button 專用圖已失效，先回落到 shared secondary family；若後續需要明確 plus glyph，應改成 icon + button 的組合，而不是回到舊 sprite-button。"
    },

    "gacha.btn.pull1": {
      "kind": "button-skin",
      "normal":   "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed":  "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "gacha.btn.pull10": {
      "kind": "button-skin",
      "normal":   "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed":  "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true,
      "note": "先對齊 commerce family 消除缺圖 warning；若後續需要凸顯 10 連推薦，再回到 gold-cta / icon badge 流程做差異化。"
    },
    "gacha.label.pull_btn": {
      "kind": "label-style",
      "fontSize": 28,
      "color": "textPrimary",
      "fontWeight": "bold"
    },
    "gacha.label.pull_cost": {
      "kind": "label-style",
      "fontSize": 18,
      "color": "textSecondary"
    },

    "gacha.btn.divination": {
      "kind": "button-skin",
      "normal":  "sprites/ui_families/common/commerce/btn_primary_normal",
      "pressed": "sprites/ui_families/common/commerce/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/commerce/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20,20,20,20],
      "allowAutoAtlas": true
    },
    "gacha.label.token_count": {
      "kind": "label-style",
      "fontSize": 20,
      "color": "warning"
    },

    "result.screen.bg": {
      "kind": "color-rect",
      "color": "background"
    },
    "item.cell.bg": {
      "kind": "color-rect",
      "color": "transparent"
    },
    "item.cell.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "item.cell.bleed": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/bleed/bleed_parchment",
      "spriteType": "sliced",
      "border": [32, 32, 32, 32],
      "opacity": 0.3
    },
    "item.cell.frame": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/item_cell/bg",
      "spriteType": "sliced",
      "border": [12, 12, 12, 12]
    },
    "parchment.bg.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "parchment.bg.noise": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/noise/paper_noise_256",
      "spriteType": "tiled",
      "opacity": 0.10,
      "blendMode": "alpha"
    },
    "parchment.bg.accent": {
      "kind": "color-rect",
      "color": "transparent"
    },
    "destiny_shop.item.bg": {
      "kind": "sprite-9slice",
      "frame": "ui/gacha/destiny_shop_item_bg",
      "border": [10,10,10,10]
    },
    "gacha.pity.carrier.bg": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/parchment/bg",
      "spriteType": "sliced",
      "border": [8, 8, 8, 8],
      "opacity": 0.75,
      "allowAutoAtlas": true,
      "comment": "D-2 QA anchor: PityInfoBar light-surface carrier，提升保底計數區在深色背景上的可讀性"
    },
    "gacha.pity.carrier.frame": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/parchment/frame",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "allowAutoAtlas": true
    }
  },

  "validation": {
    "requiredSlots": [
      "gacha.btn.pull1", "gacha.btn.pull10",
      "gacha.label.pity_small", "gacha.label.pity_big",
      "result.card.bg.SSR", "result.card.bg.SR", "result.card.bg.R",
      "currency.icon.spirit_jade", "currency.icon.bronze_charm"
    ],
    "nineSliceIntegerCheck": [
      "gacha.btn.pull1", "gacha.btn.pull10",
      "result.card.bg.SSR", "result.card.bg.SR", "result.card.bg.R",
      "result.btn.confirm"
    ]
  }
}
