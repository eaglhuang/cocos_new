{
  "id": "gacha-default",
  "version": 3,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby_gacha",
  "$fragments": ["item-cell-default", "common-parchment-default"],
  "description": "轉蛋系統 skin：主畫面、卡池分頁、抽卡按鈕、結果頁、天命商店",

  "slots": {

    "widget.header.plaque.base": { "kind": "color-rect", "color": "surfaceDeep", "alpha": 224 },
    "widget.header.plaque.fill": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/detail_header_fill", "spriteType": "simple", "allowAutoAtlas": true, "opacity": 0.92 },
    "widget.header.plaque.band": { "kind": "sprite-frame", "path": "sprites/ui_families/general_detail/formal/header_band_formal", "spriteType": "sliced", "border": [20, 0, 20, 0], "allowAutoAtlas": true, "opacity": 0.42 },
    "widget.header.plaque.title": { "kind": "label-style", "font": "fonts/newsreader/font", "fontSize": 28, "lineHeight": 30, "color": "colorWhite", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.subtitle": { "kind": "label-style", "fontSize": 16, "lineHeight": 18, "color": "secondary", "outlineWidth": 0, "horizontalAlign": "LEFT" },
    "widget.header.plaque.badge.underlay": { "kind": "sprite-frame", "path": "sprites/ui_families/common/parchment/fill", "spriteType": "sliced", "border": [16, 16, 16, 16], "allowAutoAtlas": true, "opacity": 0.9 },
