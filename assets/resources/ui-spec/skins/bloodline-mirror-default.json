{
  "id": "bloodline-mirror-default",
  "version": 1,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby",
  "slots": {
    "mirror.bg.full": {
      "kind": "sprite-frame",
      "path": "ui-spec/placeholders/bg_ink_main",
      "spriteType": "sliced",
      "border": [96, 360, 96, 420],
      "allowAutoAtlas": false
    },
    "mirror.hero.public": { "kind": "color-rect", "color": "mirrorHeroPublic", "alpha": 160 },
    "mirror.hero.spirit": { "kind": "color-rect", "color": "mirrorHeroSpirit", "alpha": 168 },
    "mirror.unowned.veil": { "kind": "color-rect", "color": "mirrorUnownedBase", "alpha": 102 },
    "mirror.unowned.badge": { "kind": "color-rect", "color": "mirrorUnownedBadge", "alpha": 204 },
    "mirror.gate": { "kind": "color-rect", "color": "mirrorGate", "alpha": 224 },
    "mirror.sigil.field": { "kind": "color-rect", "color": "mirrorSigilField", "alpha": 136 },
    "mirror.vessel.legendary": { "kind": "color-rect", "color": "mirrorVesselLegendary", "alpha": 204 },
    "mirror.badge.small": { "kind": "color-rect", "color": "mirrorBadge", "alpha": 204 },
    "mirror.story.rail": { "kind": "color-rect", "color": "mirrorStoryRail", "alpha": 224 },
    "mirror.story.cell.mortal": { "kind": "color-rect", "color": "mirrorStoryCellMortal", "alpha": 240 },
    "mirror.story.cell.rise": { "kind": "color-rect", "color": "mirrorStoryCellRise", "alpha": 240 },
    "mirror.story.cell.crisis": { "kind": "color-rect", "color": "mirrorStoryCellCrisis", "alpha": 240 },
    "mirror.story.cell.awaken": { "kind": "color-rect", "color": "mirrorStoryCellAwaken", "alpha": 240 },
    "mirror.story.cell.spirit": { "kind": "color-rect", "color": "mirrorStoryCellSpirit", "alpha": 240 },
    "mirror.button.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "mirror.label.header": {
      "kind": "label-style",
      "fontSize": 34,
      "lineHeight": 40,
      "color": "mirrorLabelHeader",
      "horizontalAlign": "CENTER"
    },
    "mirror.label.name": {
      "kind": "label-style",
      "fontSize": 28,
      "lineHeight": 34,
      "color": "mirrorLabelName",
      "horizontalAlign": "CENTER"
    },
    "mirror.label.rarity": {
      "kind": "label-style",
      "fontSize": 22,
      "lineHeight": 28,
      "color": "mirrorLabelRarity",
      "horizontalAlign": "CENTER"
    },
    "mirror.label.button": {
      "kind": "label-style",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "mirrorLabelButton",
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER"
    },
    "mirror.label.marker.public": {
      "kind": "label-style",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "mirrorLabelPublic",
      "horizontalAlign": "CENTER"
    },
    "mirror.label.marker.spirit": {
      "kind": "label-style",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "mirrorLabelSpirit",
      "horizontalAlign": "CENTER"
    },
    "mirror.label.unowned": {
      "kind": "label-style",
      "fontSize": 16,
      "lineHeight": 20,
      "color": "mirrorLabelUnowned",
      "horizontalAlign": "RIGHT"
    }
  }
}
