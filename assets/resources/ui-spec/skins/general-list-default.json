      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true,
      "opacity": 0.28,
      "offsetY": 10
