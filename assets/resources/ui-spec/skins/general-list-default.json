      "border": [22, 28, 22, 28],
      "allowAutoAtlas": true,
      "opacity": 0.95,
      "color": "#FFFFFF"
    },
    "parchment.bg.frame": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/parchment/frame",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "allowAutoAtlas": true,
      "opacity": 0.86
    },
    "parchment.bg.bleed": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/bleed/bleed_parchment",
      "spriteType": "sliced",
      "border": [24, 24, 24, 24],
      "allowAutoAtlas": true,
      "opacity": 0.18
