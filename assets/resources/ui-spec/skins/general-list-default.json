      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "general.label.faction": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 24,
      "color": "text.parchment.secondary",
      "isBold": true,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "general.label.positive": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 20,
      "lineHeight": 26,
      "color": "textPositiveOnParchment",
      "isBold": true,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "general.label.action": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 22,
      "color": "accent.gold.base",
      "isBold": true,
      "horizontalAlign": "CENTER",
      "verticalAlign": "CENTER",
