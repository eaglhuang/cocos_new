{
  "id": "general-list-default",
  "version": 6,
  "bundle": "lobby_ui",
  "atlasPolicy": "lobby_general",
  "$fragments": ["common-parchment-default", "header-rarity-plaque-default"],
  "slots": {
    "widget.header.plaque.base": {
      "kind": "color-rect",
      "color": "surfaceDeep",
      "alpha": 214
    },
    "widget.header.plaque.fill": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/general_detail/detail_header_fill",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "opacity": 0.92
    },
    "widget.header.plaque.band": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/general_detail/formal/header_band_formal",
      "spriteType": "sliced",
      "border": [20, 0, 20, 0],
      "allowAutoAtlas": true,
      "opacity": 0.42
    },
    "widget.header.plaque.title": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 34,
      "lineHeight": 36,
      "color": "text.parchment.primary",
      "outlineWidth": 0,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK",
      "isBold": true
    },
    "widget.header.plaque.subtitle": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 15,
      "lineHeight": 18,
      "color": "accent.gold.base",
      "outlineWidth": 0,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
