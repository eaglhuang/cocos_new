    "widget.header.plaque.badge.fill": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/parchment/fill",
      "spriteType": "sliced",
      "border": [16, 16, 16, 16],
      "allowAutoAtlas": true,
      "opacity": 0.96
