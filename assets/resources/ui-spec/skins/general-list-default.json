      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "list.button.primary": {
      "kind": "button-skin",
      "normal": "sprites/ui_families/common/equipment/btn_primary_normal",
      "pressed": "sprites/ui_families/common/equipment/btn_primary_pressed",
      "disabled": "sprites/ui_families/common/equipment/btn_primary_disabled",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    }
