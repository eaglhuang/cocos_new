    "general.label.header": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
      "fontSize": 18,
      "lineHeight": 24,
      "color": "text.parchment.secondary",
      "isBold": true,
      "horizontalAlign": "LEFT",
      "verticalAlign": "CENTER",
      "overflow": "SHRINK"
    },
    "general.label.headerAction": {
      "kind": "label-style",
      "font": "fonts/notosans_tc/font",
