{
  "id": "unit-info-panel-default",
  "version": 1,
  "bundle": "battle_ui",
  "atlasPolicy": "unit_info_panel",
  "_doc": "兵種資訊面板皮膚。從左滑出的小抽屜，深色水墨底板，金色分段標題線。",
  "slots": {
    "unitinfo.root.bg": {
      "kind": "color",
      "color": "surfaceSepia",
      "alpha": 255,
      "_doc": "主體底板改為近乎不透的深褐墨底，避免戰場地磚從抽屜底部透出。"
    },
    "unitinfo.root.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "unitinfo.header.bg": {
      "kind": "color",
      "color": "backgroundNavyAlt",
      "alpha": 255,
      "_doc": "Header 維持更冷一階的深墨色，讓標題區不受戰場背景干擾。"
    },
    "unitinfo.section.bg": {
      "kind": "color",
      "color": "surfaceSepiaWarm",
      "alpha": 248,
      "_doc": "Section 以更厚的深褐墨色模組承接戰場系統感，壓低底圖透視感。"
    },
    "unitinfo.type.icon": {
      "kind": "sprite-frame",
      "path": "sprites/battle/unitinfo_type_icon/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "兵種圓形圖示，TS 依 TroopType 切換 spriteFrame"
    },
    "unitinfo.btn.close": {
      "kind": "sprite-frame",
      "path": "sprites/common/btn_close_small/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_fallback": "#444C58"
    },
    "unitinfo.label.name": {
      "kind": "label-style",
      "fontSize": 16,
      "lineHeight": 22,
      "color": "secondaryLight",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "unitinfo.label.sub": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "textSteelGray",
      "horizontalAlign": "LEFT"
    },
    "unitinfo.label.section": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "secondaryLight",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "unitinfo.label.stat": {
      "kind": "label-style",
      "fontSize": 13,
      "lineHeight": 16,
      "color": "textOffWhite",
      "horizontalAlign": "LEFT"
    },
    "unitinfo.label.trait.tag": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "textCyanLight",
      "horizontalAlign": "CENTER",
      "_doc": "特性標籤文字，TS 動態建立背景底板"
    },
    "unitinfo.label.desc": {
      "kind": "label-style",
      "fontSize": 12,
      "lineHeight": 18,
      "color": "textSecondary",
      "horizontalAlign": "LEFT",
      "overflow": "clampByHeight"
    }
  }
}
