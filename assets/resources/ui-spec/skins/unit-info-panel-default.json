{
  "id": "unit-info-panel-default",
  "version": 1,
  "bundle": "battle_ui",
  "atlasPolicy": "unit_info_panel",
  "_doc": "兵種資訊面板皮膚。從左滑出的小抽屜，深色水墨底板，金色分段標題線。",
  "slots": {
    "unitinfo.root.bg": {
      "kind": "sprite-frame",
      "path": "sprites/battle/unitinfo_root_bg/spriteFrame",
      "spriteType": "sliced",
      "border": [56, 56, 56, 56],
      "bleed": 4,
      "allowAutoAtlas": true,
      "_fallback": "#10141C",
      "_doc": "主體底板：深色偏黑"
    },
    "unitinfo.root.shadow": {
      "kind": "sprite-frame",
      "path": "sprites/ui_families/common/shadow/shadow_01",
      "spriteType": "sliced",
      "border": [20, 20, 20, 20],
      "allowAutoAtlas": true
    },
    "unitinfo.header.bg": {
      "kind": "sprite-frame",
      "path": "sprites/battle/unitinfo_header_bg/spriteFrame",
      "spriteType": "sliced",
      "border": [28, 40, 28, 40],
      "allowAutoAtlas": true,
      "_fallback": "#1C2230"
    },
    "unitinfo.section.bg": {
      "kind": "sprite-frame",
      "path": "sprites/battle/unitinfo_section_bg/spriteFrame",
      "spriteType": "sliced",
      "border": [36, 36, 36, 36],
      "allowAutoAtlas": true,
      "_fallback": "#161C28"
    },
    "unitinfo.type.icon": {
      "kind": "sprite-frame",
      "path": "sprites/battle/unitinfo_type_icon/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_doc": "兵種圓形圖示，TS 依 TroopType 切換 spriteFrame"
    },
    "unitinfo.btn.close": {
      "kind": "sprite-frame",
      "path": "sprites/common/btn_close_small/spriteFrame",
      "spriteType": "simple",
      "allowAutoAtlas": true,
      "_fallback": "#444C58"
    },
    "unitinfo.label.name": {
      "kind": "label-style",
      "fontSize": 15,
      "lineHeight": 20,
      "color": "#E8E4DC",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "unitinfo.label.sub": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "#7A8899",
      "horizontalAlign": "LEFT"
    },
    "unitinfo.label.section": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "#D4AF37",
      "horizontalAlign": "LEFT",
      "isBold": true
    },
    "unitinfo.label.stat": {
      "kind": "label-style",
      "fontSize": 13,
      "lineHeight": 16,
      "color": "#C8D0DC",
      "horizontalAlign": "LEFT"
    },
    "unitinfo.label.trait.tag": {
      "kind": "label-style",
      "fontSize": 11,
      "lineHeight": 14,
      "color": "#88CCEE",
      "horizontalAlign": "CENTER",
      "_doc": "特性標籤文字，TS 動態建立背景底板"
    },
    "unitinfo.label.desc": {
      "kind": "label-style",
      "fontSize": 12,
      "lineHeight": 18,
      "color": "#9AA8B8",
      "horizontalAlign": "LEFT",
      "overflow": "clampByHeight"
    }
  }
}
