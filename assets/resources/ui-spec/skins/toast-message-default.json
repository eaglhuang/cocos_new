{
  "id": "toast-message-default",
  "version": 1,
  "bundle": "common_ui",
  "atlasPolicy": "common",
  "slots": {
    "toast.bg": {
      "kind": "color-rect",
      "color": "#403C30"
    },
    "toast.label": {
      "kind": "label-style",
      "fontSize": 24,
      "isBold": true,
      "color": "textPrimary",
