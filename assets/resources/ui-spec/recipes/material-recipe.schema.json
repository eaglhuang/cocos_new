{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "material-recipe.schema.json",
  "title": "MaterialRecipe",
  "description": "UI 材質/紋理風格契約。描述底層貼圖、紙紋雜訊、金屬感、透明度與混合模式，供 FrameRecipe 引用，也可被 skin/screen 直接引用。",
  "type": "object",
  "required": ["id", "version"],
  "additionalProperties": false,
  "properties": {
    "id":                 { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "version":            { "type": "integer", "minimum": 1 },
    "description":        { "type": "string" },
    "baseTexturePath":    { "type": "string", "description": "底層貼圖路徑（bundle 相對路徑）" },
    "baseColor":          { "type": "string", "description": "底色，hex 或 token key，疊在 baseTexture 上方" },
    "grainIntensity":     { "type": "number", "minimum": 0, "maximum": 1, "description": "紙紋/雜訊強度 0~1" },
    "grainTexturePath":   { "type": "string", "description": "雜訊/紙紋貼圖路徑" },
    "opacity":            { "type": "number", "minimum": 0, "maximum": 1 },
    "blendMode":          { "type": "string", "enum": ["alpha", "overlay", "multiply"] },
    "metallicIntensity":  { "type": "number", "minimum": 0, "maximum": 1, "description": "金屬感強度 0~1，0 = 無金屬感" },
    "aiGenerated":        { "type": "boolean", "description": "true = 由 AI 生成，需有 artRecipeRef 追溯" },
    "artRecipeRef":       { "type": "string", "description": "關聯的 ArtRecipe id（UI-2-0089 使用）" }
  }
}
