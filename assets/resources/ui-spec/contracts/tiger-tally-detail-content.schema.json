{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaId": "tiger-tally-detail-content",
  "familyId": "tiger-tally-detail",
  "version": 1,
  "description": "TigerTallyDetailComposite content contract — 戰鬥場景右側虎符詳情抽屜。",
  "fields": {
    "unitName": { "type": "string", "required": true, "bindPath": "detail.unitName" },
