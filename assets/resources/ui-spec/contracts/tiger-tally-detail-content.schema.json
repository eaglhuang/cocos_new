    "rarityLabel": { "type": "string", "required": false, "bindPath": "detail.rarityLabel" },
    "stars": { "type": "string", "required": false, "bindPath": "detail.stars" },
    "cost": { "type": "number", "required": true, "bindPath": "detail.cost" },
    "atk": { "type": "number", "required": true, "bindPath": "detail.atk" },
    "def": { "type": "number", "required": true, "bindPath": "detail.def" },
    "hp": { "type": "number", "required": true, "bindPath": "detail.hp" },
    "spd": { "type": "number", "required": true, "bindPath": "detail.spd" },
    "desc": { "type": "string", "required": false, "bindPath": "detail.desc" },
    "traits": { "type": "array", "required": false, "bindPath": "detail.traits" },
    "abilities": { "type": "array", "required": false, "bindPath": "detail.abilities" }
