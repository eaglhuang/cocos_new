{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaId": "nurture-session-content",
  "familyId": "nurture-session",
  "version": 2,
  "description": "NurtureSession canonical contract。以 structured sessionInfo / dualLayerStats / trainingProfile / supportPlan / riskPlan 為真相來源，再投影到 phase block 與 graduation tags strip 的顯示欄位。",
  "fields": {
    "sessionInfo": { "type": "object", "required": true },
    "dualLayerStats": { "type": "object", "required": true },
    "profilePresentation": { "type": "object", "required": true },
    "trainingProfile": { "type": "object", "required": true },
    "supportPlan": { "type": "object", "required": true },
    "riskPlan": { "type": "object", "required": true },
    "sessionTitle": { "type": "string", "required": true, "bindPath": "HeaderShell/SessionTitle" },
    "sessionSubtitle": { "type": "string", "required": true, "bindPath": "HeaderShell/SessionSubtitle" },
    "turnLabel": { "type": "string", "required": true, "bindPath": "HeaderShell/TurnLabel" },
    "sessionSummary": { "type": "string", "required": true, "bindPath": "HeaderShell/SessionSummary" },
    "phaseBlockTitle": { "type": "string", "required": true, "bindPath": "PhaseBlockHeader/PhaseBlockTitle" },
    "phaseBlockBody": { "type": "string", "required": true, "bindPath": "PhaseBlockHeader/PhaseBlockBody" },
    "mentorModeLabel": { "type": "string", "required": true, "bindPath": "PhaseBlockHeader/MentorModeChip/MentorModeLabel" },
    "mainCourseTitle": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/MainCourseCard/MainCourseTitle" },
    "mainCourseBody": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/MainCourseCard/MainCourseBody" },
    "supportWindowTitle": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/SupportWindowCard/SupportWindowTitle" },
    "supportWindowBody": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/SupportWindowCard/SupportWindowBody" },
    "riskWindowTitle": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/RiskWindowCard/RiskWindowTitle" },
    "riskWindowBody": { "type": "string", "required": true, "bindPath": "TrainingSummaryRow/RiskWindowCard/RiskWindowBody" },
    "graduationTagsTitle": { "type": "string", "required": true, "bindPath": "GraduationTagsStrip/GraduationTagsTitle" },
    "graduationTagsBody": { "type": "string", "required": true, "bindPath": "GraduationTagsStrip/GraduationTagsBody" }
  },
  "requiredFields": [
    "sessionInfo",
    "dualLayerStats",
    "profilePresentation",
    "trainingProfile",
    "supportPlan",
    "riskPlan",
    "sessionTitle",
    "sessionSubtitle",
    "turnLabel",
    "sessionSummary",
    "phaseBlockTitle",
    "phaseBlockBody",
    "mentorModeLabel",
    "mainCourseTitle",
    "mainCourseBody",
    "supportWindowTitle",
    "supportWindowBody",
    "riskWindowTitle",
    "riskWindowBody",
    "graduationTagsTitle",
    "graduationTagsBody"
  ]
}