    "worldMapFrontierBody": { "type": "string", "required": true, "bindPath": "ContentArea/WorldSandtableCard/FrontierPanel/FrontierBody" },
    "worldMapCoalitionBody": { "type": "string", "required": true, "bindPath": "ContentArea/WorldSandtableCard/CoalitionPanel/CoalitionBody" },
    "tournamentSeasonTitle": { "type": "string", "required": true, "bindPath": "ContentArea/WorldSandtableCard/TournamentSeasonCard/TournamentSeasonTitle" },
    "tournamentSeasonBody": { "type": "string", "required": true, "bindPath": "ContentArea/WorldSandtableCard/TournamentSeasonCard/TournamentSeasonBody" },
