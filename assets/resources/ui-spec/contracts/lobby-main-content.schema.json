    "wishAlertVisible": { "type": "boolean", "required": true, "bindPath": "ContentArea/WishAltarCard/WishAlertBadge" },
    "wishPrimaryActionLabel": { "type": "string", "required": true, "bindPath": "ContentArea/WishAltarCard/WishActionButton/WishActionLabel" },
    "intelTitle": { "type": "string", "required": true, "bindPath": "ContentArea/BattleIntelCard/IntelTitle" },
    "intelScoutBody": { "type": "string", "required": true, "bindPath": "ContentArea/BattleIntelCard/IntelRules/ScoutRule" },
