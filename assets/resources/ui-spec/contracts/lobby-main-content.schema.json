    "morningReportTitle": { "type": "string", "required": true, "bindPath": "ContentArea/MorningReportStrip/MorningReportTitle" },
    "morningReportBody": { "type": "string", "required": true, "bindPath": "ContentArea/MorningReportStrip/MorningReportBody" },
    "morningReportUnreadLabel": { "type": "string", "required": true, "bindPath": "ContentArea/MorningReportStrip/MorningReportUnreadBadge/MorningReportUnreadLabel" },
    "heroWallTitle": { "type": "string", "required": true, "bindPath": "ContentArea/HeroTaskWallCard/TitleBand/HeroWallTitle" },
    "heroWallUrgentTitle": { "type": "string", "required": true, "bindPath": "ContentArea/HeroTaskWallCard/UrgentMission/UrgentTitle" },
