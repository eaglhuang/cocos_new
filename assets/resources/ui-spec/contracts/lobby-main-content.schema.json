{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schemaId": "lobby-main-content",
  "familyId": "lobby-main",
  "version": 1,
  "description": "LobbyMain 大廳主入口內容契約，承接雙牆任務、官職區、世界沙盤、許願祭壇與預戰 intel 摘要。",
  "fields": {
