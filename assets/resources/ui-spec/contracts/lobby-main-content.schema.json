    "resourceGold",
    "resourceGem",
    "morningReportTitle",
    "morningReportBody",
    "morningReportUnreadLabel",
    "heroWallTitle",
    "heroWallUrgentTitle",
    "heroWallUrgentBody",
    "heroWallDailyTitle",
    "heroWallDailyBody",
    "dispatchBoardTitle",
    "dispatchBoardBody",
    "dispatchBoardActionLabel",
    "officerRankTitle",
    "officerAuthorityHint",
    "officerUnlockHint",
    "officerLockBadgeVisible",
    "officerPrimaryActionLabel",
    "worldMapTitle",
    "worldMapPhase",
    "worldMapFrontierBody",
    "worldMapCoalitionBody",
    "tournamentSeasonTitle",
    "tournamentSeasonBody",
    "worldCoalitionBadgeVisible",
    "worldPrimaryActionLabel",
    "wishTitle",
    "wishBody",
    "economySubsidyLabel",
    "wishAlertVisible",
    "wishPrimaryActionLabel",
    "intelTitle",
    "intelScoutBody",
    "intelChainBreakBody",
    "intelGridBody"
